<Window
    x:Class="ZapretMirrlyGUI.OverlayNotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Overlay Notification"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootContainer" Background="Transparent" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="ContainerTransform" Y="-12"/>
        </Grid.RenderTransform>

        <Grid.Resources>
            <!-- Show Animation: Slide down & Fade in -->
            <Storyboard x:Name="ShowStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootContainer"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1"
                                 Duration="0:0:0.25">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ContainerTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="-12" To="0"
                                 Duration="0:0:0.25">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Hide Animation: Slide up & Fade out -->
            <Storyboard x:Name="HideStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootContainer"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1" To="0"
                                 Duration="0:0:0.20">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ContainerTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="0" To="-12"
                                 Duration="0:0:0.20">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <!-- 1. Pure Status Notification Panel (Stacked Vertically, Icons + Real Ping Latency ONLY) -->
        <Border x:Name="StatusPanel" Padding="8,4" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible">
            <StackPanel Spacing="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Row 1: DPI Icon + Ping -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Viewbox Width="13" Height="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="DpiIconPath"
                                  Data="F1 M13 3 L8 14 L12.2 14 L11 21 L16 10 L11.8 10 Z"
                                  Fill="#00F5D4" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock x:Name="DpiPingText" Text="-- мс" FontSize="10.5" FontWeight="Bold" Foreground="#00F5D4" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Row 2: Telegram Icon + Ping -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Viewbox Width="13" Height="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="TgIconPath"
                                  Data="M3 12 L21 4 L14 20 L10 14 Z"
                                  Fill="#FF453A" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock x:Name="TgPingText" Text="-- мс" FontSize="10.5" FontWeight="Bold" Foreground="#FF453A" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 2. Connecting Panel: Pure minimal spinning amber ProgressRing without text -->
        <Border x:Name="ConnectingPanel" Padding="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
            <Grid Width="42" Height="42" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressRing x:Name="ConnectingRing" IsActive="True" Width="18" Height="18" Foreground="#FF9F1C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
