<Window
    x:Class="ZapretMirrlyGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Zapret Mirrly GUI"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource WindowBackgroundBrush}">
        <NavigationView
            x:Name="RootNavigationView"
            Background="Transparent"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneToggleButtonVisible="False"
            CompactPaneLength="64"
            PaneDisplayMode="LeftCompact"
            ItemInvoked="RootNavigationView_ItemInvoked"
            SelectionChanged="RootNavigationView_SelectionChanged">

            <NavigationView.MenuItems>
                <!-- Title Header Item -->
                <NavigationViewItem
                    x:Name="PaneToggleItem"
                    Content="Zapret Mirrly"
                    Tag="paneToggle"
                    Margin="0,8,0,8"
                    SelectsOnInvoked="False"
                    ToolTipService.ToolTip="Развернуть/свернуть меню">
                    <NavigationViewItem.Icon>
                        <ImageIcon x:Name="SidebarLogo" Width="40" Height="40" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <!-- Main Control Panel -->
                <NavigationViewItem
                    x:Name="DashboardItem"
                    Content="DPI обход Discord + Youtube"
                    Tag="dashboard"
                    ToolTipService.ToolTip="Обход для медиа и чатов">
                    <NavigationViewItem.Icon>
                        <!-- ДПИ обход: сеть + зигзаг сигнала прорывающегося через DPI-барьер -->
                        <PathIcon Data="M12 2 L20 5.5 L20 11 Q20 17 12 21 Q4 17 4 11 L4 5.5 Z M8 12 L10.5 9 L12.5 13 L14.5 10 L16 12" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Telegram Proxy (TgWsProxy) -->
                <NavigationViewItem
                    x:Name="TgWsProxyItem"
                    Content="Telegram Proxy"
                    Tag="tgwsproxy"
                    ToolTipService.ToolTip="Обход блокировок Telegram">
                    <NavigationViewItem.Icon>
                        <!-- Telegram Proxy: чистый бумажный самолётик Telegram -->
                        <PathIcon Data="M3 12 L21 4 L14 20 L10 14 Z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Lists Editor -->
                <NavigationViewItem
                    x:Name="ListsItem"
                    Content="Списки обхода"
                    Tag="lists"
                    ToolTipService.ToolTip="Редактирование списков">
                    <NavigationViewItem.Icon>
                        <!-- Иконка "Список" -->
                        <PathIcon Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <!-- Logs Console -->
                <NavigationViewItem
                    x:Name="LogsItem"
                    Content="Журнал логов"
                    Tag="logs"
                    ToolTipService.ToolTip="Логи в реальном времени">
                    <NavigationViewItem.Icon>
                        <!-- Иконка "Консоль терминала" -->
                        <PathIcon Data="M20 4H4c-1.11 0-2 .89-2 2v12c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.11-.9-2-2-2zm0 14H4V8h16v10zm-2-1h-6v-2h6v2zM7.5 17l-1.41-1.41L8.67 13l-2.59-2.59L7.5 9l4 4-4 4z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Diagnostics & Conflict Checker -->
                <NavigationViewItem
                    x:Name="DiagnosticsItem"
                    Content="Диагностика"
                    Tag="diagnostics"
                    ToolTipService.ToolTip="Тестирование и проблемы">
                    <NavigationViewItem.Icon>
                        <!-- Иконка "Пульс (Сердцебиение / Мониторинг)" -->
                        <PathIcon Data="M 16 3 L 10.4 17.6 L 7.5 10 L 2 10 L 2 12 L 6 12 L 9.6 21.4 L 15.5 6 L 18 12 L 22 12 L 22 10 L 19.5 10 Z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <!-- Update Status Item -->
                <NavigationViewItem
                    x:Name="UpdateStatusItem"
                    Content="Версия актуальна"
                    Tag="update_status"
                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon x:Name="UpdateStatusIcon" Glyph="&#xE930;" Foreground="#8A8A8F" />
                    </NavigationViewItem.Icon>
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="UpdateStatusToolTip" Placement="Right">
                            <StackPanel Spacing="6" Padding="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="UpdateTooltipIcon" Glyph="&#xE930;" FontSize="14" Foreground="#00F5D4" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="UpdateTooltipTitle" Text="Приложение обновлено" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="UpdateTooltipDesc" Text="У вас установлена последняя версия Zapret Mirrly GUI (v1.1.2)." FontSize="11" Opacity="0.8" TextWrapping="Wrap" MaxWidth="220"/>
                            </StackPanel>
                        </ToolTip>
                    </ToolTipService.ToolTip>
                </NavigationViewItem>

                <!-- Support / About -->
                <NavigationViewItem
                    x:Name="SupportItem"
                    Content="Поддержать"
                    Tag="support"
                    ToolTipService.ToolTip="Поддержать автора">
                    <NavigationViewItem.Icon>
                        <!-- Иконка "Кофе" -->
                        <PathIcon Data="M20,3H4v10c0,2.21,1.79,4,4,4h6c2.21,0,4-1.79,4-4v-3h2c1.11,0,2-0.89,2-2V5C22,3.89,21.11,3,20,3z M18,8h-2V5h2V8z M4,19h16v2H4V19z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Guide / Help -->
                <NavigationViewItem
                    x:Name="GuideItem"
                    Content="Инструкция"
                    Tag="guide"
                    ToolTipService.ToolTip="Справка и обновления">
                    <NavigationViewItem.Icon>
                        <!-- Иконка "Книга" -->
                        <PathIcon Data="M21,5c-1.11-0.35-2.33-0.5-3.5-0.5c-1.95,0-4.05,0.4-5.5,1.5c-1.45-1.1-3.55-1.5-5.5-1.5S2.45,4.9,1,6v14.65c0,0.25,0.25,0.5,0.5,0.5c0.1,0,0.15-0.05,0.25-0.05C3.1,20.45,5.05,20,6.5,20c1.95,0,4.05,0.4,5.5,1.5c1.35-0.85,3.8-1.5,5.5-1.5c1.65,0,3.35,0.3,4.75,1.05c0.1,0.05,0.15,0.05,0.25,0.05c0.25,0,0.5-0.25,0.5-0.5V6C22.4,5.55,21.75,5.25,21,5z M21,18.5c-1.1-0.35-2.3-0.5-3.5-0.5c-1.7,0-4.15,0.65-5.5,1.5V8c1.35-0.85,3.8-1.5,5.5-1.5c1.2,0,2.4,0.15,3.5,0.5V18.5z M17.5,10.5c0.88,0,1.73,0.09,2.5,0.26V9.24C19.21,9.09,18.36,9,17.5,9c-1.28,0-2.46,0.16-3.5,0.47v1.57C14.99,10.69,16.18,10.5,17.5,10.5z M17.5,13.16c0.88,0,1.73,0.09,2.5,0.26V11.9c-0.79-0.15-1.64-0.24-2.5-0.24c-1.28,0-2.46,0.16-3.5,0.47v1.57C14.99,13.36,16.18,13.16,17.5,13.16z M17.5,15.83c0.88,0,1.73,0.09,2.5,0.26v-1.52c-0.79-0.15-1.64-0.24-2.5-0.24c-1.28,0-2.46,0.16-3.5,0.47v1.57C14.99,16.02,16.18,15.83,17.5,15.83z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- General Settings -->
                <NavigationViewItem
                    x:Name="SettingsItem"
                    Content="Настройки"
                    Tag="settings"
                    ToolTipService.ToolTip="Настройки обхода">
                    <NavigationViewItem.Icon>
                        <!-- Иконка "Шестеренка" -->
                        <PathIcon Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="RootFrame" CacheSize="10" />
        </NavigationView>

        <!-- Custom TitleBar area for hit testing -->
        <Grid VerticalAlignment="Top" Height="48" Background="Transparent">
            <Border
                x:Name="AppTitleBar"
                Margin="64,0,0,0"
                Background="Transparent"
                IsHitTestVisible="True" />
        </Grid>

        <!-- App Update Notification Overlay -->
        <Grid x:Name="UpdateNotificationOverlay" Visibility="Collapsed" Opacity="0">
            <Grid.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6" GradientOrigin="0.5,0.5">
                    <GradientStop Color="#4A554A3B" Offset="0.0"/> <!-- 29% opacity warm gold highlight -->
                    <GradientStop Color="#CC0A0908" Offset="0.6"/> <!-- 80% opacity dark obsidian -->
                    <GradientStop Color="#FA050505" Offset="1.0"/> <!-- 98% opacity black -->
                </RadialGradientBrush>
            </Grid.Background>
            <Grid.Resources>
                <!-- Storyboard for fading in/out and scaling -->
                <Storyboard x:Name="ShowUpdateOverlayStoryboard">
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateNotificationOverlay"
                        Storyboard.TargetProperty="Opacity"
                        To="1.0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateCardScale"
                        Storyboard.TargetProperty="ScaleX"
                        To="1.0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateCardScale"
                        Storyboard.TargetProperty="ScaleY"
                        To="1.0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateCardTranslate"
                        Storyboard.TargetProperty="Y"
                        To="0" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                <Storyboard x:Name="HideUpdateOverlayStoryboard">
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateNotificationOverlay"
                        Storyboard.TargetProperty="Opacity"
                        To="0.0" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateCardScale"
                        Storyboard.TargetProperty="ScaleX"
                        To="0.9" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateCardScale"
                        Storyboard.TargetProperty="ScaleY"
                        To="0.9" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateCardTranslate"
                        Storyboard.TargetProperty="Y"
                        To="40" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseIn"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                <!-- Looping scanline animation (VHS scan sweep) -->
                <Storyboard x:Name="ScanlineStoryboard" RepeatBehavior="Forever">
                    <DoubleAnimation
                        Storyboard.TargetName="ScanlineTransform"
                        Storyboard.TargetProperty="Y"
                        From="-10" To="730" Duration="0:0:6.0"/>
                </Storyboard>
            </Grid.Resources>

            <Border
                x:Name="UpdateCard"
                MaxWidth="980"
                MaxHeight="725"
                Height="Auto"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Margin="60,16"
                Style="{StaticResource GlassCardStyle}"
                Padding="0"
                Background="#141311"
                BorderBrush="#2F2B26"
                BorderThickness="1"
                CornerRadius="16"
                RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="UpdateCardScale" ScaleX="0.9" ScaleY="0.9" />
                        <TranslateTransform x:Name="UpdateCardTranslate" Y="40" />
                    </TransformGroup>
                </Border.RenderTransform>

                <Grid ColumnDefinitions="300,*">
                    <!-- Left Column: Highlights Panel (Sidebar) -->
                    <Grid Grid.Column="0">
                        <Border CornerRadius="15,0,0,15" BorderThickness="0,0,1,0" BorderBrush="#25221F">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1816" Offset="0.0"/>
                                    <GradientStop Color="#23201D" Offset="0.5"/>
                                    <GradientStop Color="#1D1B19" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>


                        <StackPanel Padding="24" Spacing="16">
                            <!-- Header -->
                            <StackPanel Spacing="6" Margin="0,5,0,10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock x:Name="SidebarSubtitleText" Text="СВЕЖИЙ РЕЛИЗ" FontSize="10" FontWeight="Black" CharacterSpacing="120" Foreground="#A79A83" Opacity="0.8" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="20" Height="20" CornerRadius="10" Background="#3D3220" BorderBrush="#5C4B30" BorderThickness="1" HorizontalAlignment="Right">
                                        <FontIcon Glyph="&#xE785;" FontSize="9" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="Что нового?" FontSize="24" FontWeight="Black" Foreground="#F6F2EA" CharacterSpacing="-0.5"/>
                                <TextBlock Text="Автоматический анализ изменений в этой версии:" FontSize="10.5" Foreground="#A79A83" Opacity="0.6" Margin="0,2,0,0" TextWrapping="Wrap" LineHeight="14"/>
                            </StackPanel>

                            <!-- Highlight 1: Features -->
                            <Grid x:Name="FeatureHighlightRow" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border x:Name="FeatureHighlightIconBorder" Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#2C2925" BorderBrush="#453E36" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <FontIcon x:Name="FeatureHighlightIcon" Glyph="&#xE734;" FontSize="16" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock x:Name="FeatureHighlightTitle" Text="Новые Фичи" FontSize="13" FontWeight="Bold" Foreground="#E2DDD5"/>
                                    <TextBlock x:Name="FeatureHighlightDesc" Text="Новые возможности и функции" FontSize="11" Foreground="#A09B92" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border x:Name="FeatureHighlightBadge" Grid.Column="2" Padding="6,2" CornerRadius="6" Background="#3D3A35" VerticalAlignment="Center">
                                    <TextBlock x:Name="FeatureHighlightBadgeText" Text="НОВОЕ" FontSize="9" FontWeight="Bold" Foreground="#FFD700"/>
                                </Border>
                            </Grid>

                            <!-- Highlight 2: Speed/Performance -->
                            <Grid x:Name="SpeedHighlightRow" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border x:Name="SpeedHighlightIconBorder" Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#25282A" BorderBrush="#35404A" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <FontIcon x:Name="SpeedHighlightIcon" Glyph="&#xE839;" FontSize="16" Foreground="#00F5D4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock x:Name="SpeedHighlightTitle" Text="Максимум Скорости" FontSize="13" FontWeight="Bold" Foreground="#E2DDD5"/>
                                    <TextBlock x:Name="SpeedHighlightDesc" Text="Оптимизация и ускорение" FontSize="11" Foreground="#A09B92" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border x:Name="SpeedHighlightBadge" Grid.Column="2" Padding="6,2" CornerRadius="6" Background="#1D2A2B" VerticalAlignment="Center">
                                    <TextBlock x:Name="SpeedHighlightBadgeText" Text="УСКОРЕНО" FontSize="9" FontWeight="Bold" Foreground="#00F5D4"/>
                                </Border>
                            </Grid>

                            <!-- Highlight 3: Stability/Fixes -->
                            <Grid x:Name="StabilityHighlightRow" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border x:Name="StabilityHighlightIconBorder" Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#2B2425" BorderBrush="#453435" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <FontIcon x:Name="StabilityHighlightIcon" Glyph="&#xE73E;" FontSize="16" Foreground="#FF9F1C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock x:Name="StabilityHighlightTitle" Text="Стабильность" FontSize="13" FontWeight="Bold" Foreground="#E2DDD5"/>
                                    <TextBlock x:Name="StabilityHighlightDesc" Text="Исправление багов и ошибок" FontSize="11" Foreground="#A09B92" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border x:Name="StabilityHighlightBadge" Grid.Column="2" Padding="6,2" CornerRadius="6" Background="#342323" VerticalAlignment="Center">
                                    <TextBlock x:Name="StabilityHighlightBadgeText" Text="ИСПРАВЛЕНО" FontSize="9" FontWeight="Bold" Foreground="#FF9F1C"/>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Grid>

                    <!-- Right Column: Changelog and Actions -->
                    <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Padding="28" RowSpacing="16" Background="#11100F">
                        <!-- Top Header -->
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock x:Name="UpdateModalTitleText" Text="Доступно обновление!" FontSize="18" FontWeight="ExtraBold" Foreground="#F6F2EA" />
                                <TextBlock x:Name="UpdateTagNameText" Text="Версия v1.0.0" FontSize="12" Foreground="#A79A83" FontWeight="Medium" Visibility="Collapsed" />
                            </StackPanel>

                            <!-- Badges -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border x:Name="UpdateStableBadge" BorderBrush="#00F5D4" BorderThickness="1.5" CornerRadius="12" Padding="8,3" Background="#1000F5D4" Visibility="Collapsed">
                                    <TextBlock Text="СТАБИЛЬНЫЙ" FontSize="9" Foreground="#00F5D4" FontWeight="Bold" CharacterSpacing="50"/>
                                </Border>
                                <Border x:Name="UpdatePrereleaseBadge" BorderBrush="#FF9F1C" BorderThickness="1.5" CornerRadius="12" Padding="8,3" Background="#10FF9F1C" Visibility="Collapsed">
                                    <TextBlock Text="ПРЕДРЕЛИЗ" FontSize="9" Foreground="#FF9F1C" FontWeight="Bold" CharacterSpacing="50"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Scrollable Changelog -->
                        <Border Grid.Row="1" Background="#0C0B0A" BorderBrush="#201F1E" BorderThickness="1" CornerRadius="10" Padding="20">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <RichTextBlock x:Name="UpdateChangelogText" FontSize="14" TextWrapping="Wrap" Foreground="#E2DDD5" LineHeight="26" SelectionHighlightColor="Transparent" />
                            </ScrollViewer>
                        </Border>

                        <!-- Actions Grid -->
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="0,4,0,0">
                            <!-- Install (Primary) - Glowing Gold Accent Style -->
                            <Button x:Name="InstallUpdateButton" Grid.Column="0" Click="DownloadUpdate_Click" Style="{StaticResource PremiumAccentButtonStyle}" Height="38" HorizontalAlignment="Stretch" CornerRadius="8" Background="#A79A83" Foreground="#121110">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="#121110" FontWeight="Bold"/>
                                    <TextBlock Text="Установить сейчас" FontWeight="Bold" Foreground="#121110" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Skip -->
                            <Button x:Name="SkipVersionButton" Grid.Column="1" Click="SkipVersion_Click" Height="38" Width="105" CornerRadius="8" BorderBrush="#302D2A" Background="Transparent" Foreground="#A79A83">
                                <TextBlock Text="Пропустить" FontSize="12.5"/>
                            </Button>

                            <!-- Close / Later -->
                            <Button x:Name="CloseUpdateOverlayButton" Grid.Column="2" Click="CloseUpdateOverlay_Click" Height="38" Width="90" CornerRadius="8" BorderBrush="#302D2A" Background="Transparent" Foreground="#A79A83">
                                <TextBlock x:Name="CloseUpdateOverlayButtonText" Text="Позже" FontSize="12.5"/>
                            </Button>
                        </Grid>
                    </Grid>

                    <!-- Futuristic VHS scan sweep line overlaying the entire card -->
                    <Grid Grid.Column="0" Grid.ColumnSpan="2" IsHitTestVisible="False" Opacity="0.08" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Border x:Name="ScanlineSweep" Height="2.5" VerticalAlignment="Top" HorizontalAlignment="Stretch" CornerRadius="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00FFD700" Offset="0.0"/>
                                    <GradientStop Color="#FFFFD700" Offset="0.5"/>
                                    <GradientStop Color="#00FFD700" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ScanlineTransform" Y="-10"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
