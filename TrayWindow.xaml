<Window
    x:Class="ZapretMirrlyGUI.TrayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent" IsTabStop="False">
        <!-- Main container with high transparency to let the Acrylic glass backdrop shine through -->
        <Border x:Name="WindowBorder" Margin="0" CornerRadius="12" BorderThickness="0" Background="#80101011" IsTabStop="False">
            <Border.Resources>
                <!-- Pulsing animation for update badge -->
                <Storyboard x:Name="UpdatePulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation
                        Storyboard.TargetName="UpdateBadgeBorder"
                        Storyboard.TargetProperty="Opacity"
                        From="0.7" To="1.0"
                        Duration="0:0:1.1" />
                </Storyboard>
            </Border.Resources>
            <Grid IsTabStop="False">
                <!-- 1. VPN Widget Panel (Shown on Left-Click) -->
                <StackPanel x:Name="VpnPanel" Padding="16,18,16,16" Spacing="10" IsTabStop="False">
                    <!-- Header -->
                    <Grid IsTabStop="False">
                        <TextBlock Text="Mirrly Zapret" FontWeight="Bold" FontSize="11" Foreground="#A79A83" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <TextBlock x:Name="TrayVersionText" Text="v1.0.3" FontSize="10" Foreground="#4A4A4F" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Update badge (hidden until update is available) -->
                    <Border x:Name="UpdateBadgeBorder"
                            Background="#1FFF9F1C"
                            BorderBrush="#40FF9F1C"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="8,5"
                            Visibility="Collapsed"
                            IsTabStop="False">
                        <Button x:Name="UpdateBadgeButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                UseSystemFocusVisuals="False"
                                IsTabStop="False"
                                Click="UpdateBadgeButton_Click"
                                HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <FontIcon Grid.Column="0" Glyph="&#xE896;" FontSize="10" Foreground="#FF9F1C" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="UpdateBadgeText" Grid.Column="1" Text="Доступно обновление" FontSize="10" FontWeight="SemiBold" Foreground="#FF9F1C" VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="9" Foreground="#80FF9F1C" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </Grid>
                        </Button>
                    </Border>

                    <!-- Power Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="24" HorizontalAlignment="Center" Width="180" IsTabStop="False">
                        <!-- Zapret Toggle -->
                        <StackPanel Grid.Column="0" Spacing="8" HorizontalAlignment="Center">
                            <Button x:Name="PowerButton" Click="PowerButton_Click" Width="56" Height="56" CornerRadius="28" BorderThickness="2" HorizontalAlignment="Center" Padding="0" UseSystemFocusVisuals="False" IsTabStop="False" MinWidth="0" MinHeight="0">
                                <Button.Content>
                                    <FontIcon x:Name="PowerIcon" Glyph="&#xE7E8;" FontSize="20" />
                                </Button.Content>
                            </Button>
                            <TextBlock Text="Обход DPI" FontSize="9.5" FontWeight="SemiBold" Opacity="0.8" HorizontalAlignment="Center" />
                        </StackPanel>
 
                        <!-- Telegram Proxy Toggle -->
                        <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Center">
                            <Button x:Name="TgPowerButton" Click="TgPowerButton_Click" Width="56" Height="56" CornerRadius="28" BorderThickness="2" HorizontalAlignment="Center" Padding="0" UseSystemFocusVisuals="False" IsTabStop="False" MinWidth="0" MinHeight="0">
                                <Button.Content>
                                    <FontIcon x:Name="TgPowerIcon" Glyph="&#xE122;" FontSize="20">
                                        <FontIcon.RenderTransform>
                                            <RotateTransform Angle="-45" CenterX="10" CenterY="10" />
                                        </FontIcon.RenderTransform>
                                    </FontIcon>
                                </Button.Content>
                            </Button>
                            <TextBlock Text="Telegram" FontSize="9.5" FontWeight="SemiBold" Opacity="0.8" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <Button x:Name="ToggleAllButton" Click="ToggleAllButton_Click" HorizontalAlignment="Center" Padding="16,5,16,5" CornerRadius="6" BorderThickness="0" Background="#15FFFFFF">
                        <TextBlock x:Name="ToggleAllTextBlock" Text="Запустить всё" FontSize="9.5" FontWeight="SemiBold" Foreground="#A79A83" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>

                    <!-- Active Preset Info Card -->
                    <Border Background="#1C1C1D" CornerRadius="6" Padding="8,5" BorderThickness="1" BorderBrush="#252526" IsTabStop="False">
                        <Grid ColumnDefinitions="*,Auto" IsTabStop="False">
                            <StackPanel Grid.Column="0" Spacing="1" IsTabStop="False">
                                <TextBlock Text="АКТИВНЫЙ ПРЕСЕТ" FontSize="7" FontWeight="Bold" Foreground="#8E8E93" />
                                <TextBlock x:Name="ActivePresetNameText" Text="general.bat" FontSize="10" FontWeight="SemiBold" Foreground="#FFFFFF" />
                            </StackPanel>
                            <FontIcon Grid.Column="1" Glyph="&#xE8B7;" FontSize="11" Foreground="#8E8E93" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Footer Buttons -->
                    <Grid ColumnDefinitions="*,*" IsTabStop="False">
                        <Button Grid.Column="0" Click="OpenFullAppButton_Click" HorizontalAlignment="Stretch" Margin="0,0,4,0" Height="26" Padding="0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7F4;" FontSize="9" />
                                <TextBlock Text="Открыть" FontSize="10" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Click="ExitAppButton_Click" HorizontalAlignment="Stretch" Margin="4,0,0,0" Background="#22FF453A" BorderThickness="0" Height="26" Padding="0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE10A;" FontSize="9" Foreground="#FF453A" />
                                <TextBlock Text="Выйти" FontSize="10" Foreground="#FF453A" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- 2. Modern Context Menu Panel (Shown on Right-Click) -->
                <StackPanel x:Name="MenuPanel" Padding="4" Spacing="1" Visibility="Collapsed" VerticalAlignment="Center" IsTabStop="False">
                    <!-- Main Actions Group -->
                    <Button Click="OpenFullAppButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7F4;" FontSize="11" Foreground="#A79A83" />
                            <TextBlock Text="Открыть Mirrly" FontSize="11" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="MenuConnectTelegramButton" Click="ConnectTelegramButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE122;" FontSize="11" Foreground="#A79A83">
                                <FontIcon.RenderTransform>
                                    <RotateTransform Angle="-45" CenterX="5.5" CenterY="5.5" />
                                </FontIcon.RenderTransform>
                            </FontIcon>
                            <TextBlock Text="Подключить Telegram" FontSize="11" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                    <Button Click="ToggleAllButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon x:Name="MenuToggleAllIcon" Glyph="&#xE7E8;" FontSize="11" />
                            <TextBlock x:Name="MenuToggleAllText" Text="Запустить всё" FontSize="11" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                    <Button Click="MenuDiagnosticsButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D2;" FontSize="11" Foreground="#A79A83" />
                            <TextBlock Text="Запустить диагностику" FontSize="11" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="#18FFFFFF" Margin="6,2" IsTabStop="False" />

                    <!-- Bottom Settings & System Group -->
                    <Button Click="OpenSettingsButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE713;" FontSize="11" Foreground="#A79A83" />
                            <TextBlock Text="Настройки" FontSize="11" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                    <Button Click="ExitAppButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE10A;" FontSize="11" Foreground="#FF453A" />
                            <TextBlock Text="Выход" FontSize="11" Foreground="#FF453A" />
                        </StackPanel>
                    </Button>

                    <!-- Update menu item (hidden until update is available) -->
                    <Button x:Name="MenuUpdateButton"
                            Click="MenuUpdateButton_Click"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Height="28"
                            Padding="12,0"
                            CornerRadius="4"
                            UseSystemFocusVisuals="False"
                            IsTabStop="False"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE896;" FontSize="11" Foreground="#FF9F1C" />
                            <TextBlock x:Name="MenuUpdateText" Text="Обновить" FontSize="11" Foreground="#FF9F1C" />
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="#18FFFFFF" Margin="6,2" IsTabStop="False" />

                    <!-- Version label in menu -->
                    <Border Padding="12,2" IsTabStop="False">
                        <TextBlock x:Name="MenuVersionText" Text="Zapret Mirrly GUI v1.1.0" FontSize="9" Foreground="#3CFFFFFF" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
