<Window
    x:Class="ZapretMirrlyGUI.TrayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid Background="Transparent" IsTabStop="False">
        <!-- Main container with high transparency to let the Mica glass backdrop shine through -->
        <Border x:Name="WindowBorder" CornerRadius="12" BorderThickness="0" Background="#E6101011" IsTabStop="False">
            <Grid IsTabStop="False">
                <!-- 1. VPN Widget Panel (Shown on Left-Click) -->
                <Grid x:Name="VpnPanel" Padding="14" IsTabStop="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Header -->
                        <RowDefinition Height="*" />    <!-- Power Toggle -->
                        <RowDefinition Height="Auto" /> <!-- Preset Info -->
                        <RowDefinition Height="Auto" /> <!-- Footer Actions -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,10" IsTabStop="False">
                        <TextBlock Text="Mirrly Zapret" FontWeight="Bold" FontSize="11" Foreground="#A79A83" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Power Button & Status -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" IsTabStop="False">
                        <Button x:Name="PowerButton" Click="PowerButton_Click" Width="68" Height="68" CornerRadius="34" BorderThickness="2" HorizontalAlignment="Center" Padding="0" UseSystemFocusVisuals="False" IsTabStop="False">
                            <Button.Content>
                                <FontIcon x:Name="PowerIcon" Glyph="&#xE7E8;" FontSize="22" />
                            </Button.Content>
                        </Button>

                        <StackPanel Spacing="1" HorizontalAlignment="Center" IsTabStop="False">
                            <TextBlock x:Name="StatusTextBlock" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock x:Name="StatusSubTextBlock" FontSize="9" Opacity="0.5" HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Active Preset Info Card -->
                    <Border Grid.Row="2" Background="#1C1C1D" CornerRadius="6" Padding="8,5" Margin="0,8,0,8" BorderThickness="1" BorderBrush="#252526" IsTabStop="False">
                        <Grid ColumnDefinitions="*,Auto" IsTabStop="False">
                            <StackPanel Grid.Column="0" Spacing="1" IsTabStop="False">
                                <TextBlock Text="АКТИВНЫЙ ПРЕСЕТ" FontSize="7" FontWeight="Bold" Foreground="#8E8E93" />
                                <TextBlock x:Name="ActivePresetNameText" Text="general.bat" FontSize="10" FontWeight="SemiBold" Foreground="#FFFFFF" />
                            </StackPanel>
                            <FontIcon Grid.Column="1" Glyph="&#xE8B7;" FontSize="11" Foreground="#8E8E93" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Footer Buttons -->
                    <Grid Grid.Row="3" ColumnDefinitions="*,*" IsTabStop="False">
                        <Button Grid.Column="0" Click="OpenFullAppButton_Click" HorizontalAlignment="Stretch" Margin="0,0,4,0" Height="26" Padding="0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7F4;" FontSize="9" />
                                <TextBlock Text="Открыть" FontSize="10" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Click="ExitAppButton_Click" HorizontalAlignment="Stretch" Margin="4,0,0,0" Background="#22FF453A" BorderThickness="0" Height="26" Padding="0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE10A;" FontSize="9" Foreground="#FF453A" />
                                <TextBlock Text="Выйти" FontSize="10" Foreground="#FF453A" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <!-- 2. Modern Context Menu Panel (Shown on Right-Click) -->
                <StackPanel x:Name="MenuPanel" Padding="4" Spacing="1" Visibility="Collapsed" VerticalAlignment="Center" IsTabStop="False">
                    <Button Click="OpenFullAppButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7F4;" FontSize="11" Foreground="#A79A83" />
                            <TextBlock Text="Открыть Mirrly" FontSize="11" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                    <Button Click="PowerButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon x:Name="MenuPowerIcon" Glyph="&#xE7E8;" FontSize="11" />
                            <TextBlock x:Name="MenuPowerText" Text="Включить обход" FontSize="11" Foreground="#FFFFFF" />
                        </StackPanel>
                    </Button>
                    
                    <Border Height="1" Background="#18FFFFFF" Margin="6,2" IsTabStop="False" />
                    
                    <Button Click="ExitAppButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Height="28" Padding="12,0" CornerRadius="4" UseSystemFocusVisuals="False" IsTabStop="False">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE10A;" FontSize="11" Foreground="#FF453A" />
                            <TextBlock Text="Выход" FontSize="11" Foreground="#FF453A" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
