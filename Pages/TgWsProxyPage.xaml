<Page
    x:Class="ZapretMirrlyGUI.Pages.TgWsProxyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- LEFT COLUMN: Monitor + Link + Log                       -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header with Top-Bar Metrics -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Title & Subtitle -->
                <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Транспортный прокси Telegram" Style="{StaticResource PremiumPageTitleStyle}" FontSize="22" />
                    <TextBlock Text="Запуск TgWsProxy для параллельного обхода блокировок Telegram на ПК" Style="{StaticResource PremiumSubtitleStyle}" FontSize="12" />
                </StackPanel>

                <!-- Right: Top-Bar Telegram Proxy Metrics -->
                <StackPanel Grid.Column="1" x:Name="TopTgMetricsPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="DC2:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.65" FontSize="11" />
                        <TextBlock x:Name="Dc2PingText" Text="{x:Bind ViewModel.Dc2PingText, Mode=OneWay}" Foreground="{x:Bind ViewModel.Dc2PingBrush, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" FontSize="11" />
                    </StackPanel>

                    <TextBlock Text="│" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.3" FontSize="11" VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="DC4:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.65" FontSize="11" />
                        <TextBlock x:Name="Dc4PingText" Text="{x:Bind ViewModel.Dc4PingText, Mode=OneWay}" Foreground="{x:Bind ViewModel.Dc4PingBrush, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" FontSize="11" />
                    </StackPanel>

                    <TextBlock Text="│" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.3" FontSize="11" VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Прокси:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.65" FontSize="11" />
                        <TextBlock x:Name="ProxyPortText" Text="{x:Bind ViewModel.ProxyPortDisplayText, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" FontSize="11" Foreground="#A79A83" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ─── CONNECTION MONITOR & ACTIONS ─── -->
            <StackPanel Grid.Row="1" x:Name="TgLeftMonitorPanel" Spacing="16" Margin="0,0,0,16">
                <!-- Monitor Card -->
                <Border Style="{StaticResource GlassCardStyle}" Padding="0" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Top band: Status -->
                        <Grid Grid.Row="0" Padding="24,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Pulsing status orb -->
                            <Border Grid.Column="0" x:Name="StatusOrbOuter" Width="52" Height="52" CornerRadius="26" Margin="0,0,20,0" VerticalAlignment="Center" Background="{x:Bind ViewModel.StatusOrbBg, Mode=OneWay}">
                                <Border x:Name="StatusOrbInner" Width="34" Height="34" CornerRadius="17" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{x:Bind ViewModel.StatusOrbInnerBg, Mode=OneWay}" Opacity="{x:Bind ViewModel.StatusOrbInnerOpacity, Mode=OneWay}">
                                    <FontIcon x:Name="StatusIndicatorIcon" Glyph="{x:Bind ViewModel.StatusIndicatorIconGlyph, Mode=OneWay}" Foreground="{x:Bind ViewModel.StatusIconFg, Mode=OneWay}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>

                            <!-- Status text -->
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock Text="СОСТОЯНИЕ СЛУЖБЫ PROXY" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                                <TextBlock x:Name="StatusText" Text="{x:Bind ViewModel.StatusTitle, Mode=OneWay}" Style="{StaticResource MirrlyTextLargeStyle}" FontSize="17" FontWeight="Bold" />
                                <TextBlock x:Name="ServiceStatusText" Text="{x:Bind ViewModel.ServiceNote, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                            </StackPanel>
                        </Grid>

                        <!-- Bottom band: Actions -->
                        <Grid Grid.Row="1" Padding="24,0,24,20" ColumnDefinitions="*,*">
                            <!-- Toggle Button -->
                            <Button Grid.Column="0" x:Name="ActionBypassButton" Command="{x:Bind ViewModel.ToggleProxyCommand}" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Stretch" Height="48" Margin="0,0,8,0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" HorizontalAlignment="Center" x:Name="ActionBypassText" Text="{x:Bind ViewModel.ActionButtonText, Mode=OneWay}" FontWeight="Bold" Style="{StaticResource MirrlyTextMediumStyle}" VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <!-- Telegram Connect Link -->
                            <Button Grid.Column="1" x:Name="ConnectTelegramButton" Command="{x:Bind ViewModel.ConnectTelegramCommand}" IsEnabled="{x:Bind ViewModel.IsConnectTelegramEnabled, Mode=OneWay}" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Stretch" Height="48" Margin="8,0,0,0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" HorizontalAlignment="Center" Text="Подключить Telegram" FontWeight="Bold" Style="{StaticResource MirrlyTextMediumStyle}" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ─── LAUNCH LOG ─── -->
            <Border Grid.Row="2" x:Name="TgLogCard" Style="{StaticResource GlassCardStyle}" Background="{ThemeResource ConsoleBackgroundBrush}" BorderBrush="{ThemeResource ConsoleBorderBrush}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Log header -->
                    <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource WidgetCardBackgroundBrush}" BorderBrush="{ThemeResource ConsoleBorderBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9F5;" FontSize="12" Foreground="#A79A83" />
                            <TextBlock Text="ЛОГИ РАБОТЫ TGWSROOT" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button x:Name="CopyLogButton" Command="{x:Bind ViewModel.CopyLogCommand}" Padding="0" Height="26" Width="26" ToolTipService.ToolTip="Копировать журнал запуска">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="13" />
                            </Button>
                            <Button x:Name="ClearLogButton" Command="{x:Bind ViewModel.ClearLogCommand}" Padding="0" Height="26" Width="26" ToolTipService.ToolTip="Очистить журнал">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" FontSize="13" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Log output -->
                    <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14,10">
                        <TextBlock x:Name="LaunchLogTextBlock" Text="{x:Bind ViewModel.LaunchLogText, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource ConsoleForegroundBrush}" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- RIGHT COLUMN: Strategy Config & Info                   -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="1" x:Name="TgRightScrollViewer" Margin="0,80,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="16" Margin="0,0,12,0">
                <!-- Configuration Card -->
                <Border Style="{StaticResource GlassCardStyle}" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="НАСТРОЙКИ TGWS-PROXY" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />

                        <!-- Port Setting -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Порт прокси (SOCKS5/MTProto)" FontSize="12" Opacity="0.8" />
                                <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Порт, на котором будет запущен SOCKS5/MTProto прокси-сервер. Этот порт нужно указать в настройках Telegram на вашем устройстве." VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="ProxyPortTextBox" Text="{x:Bind ViewModel.ProxyPortText, Mode=TwoWay}" PlaceholderText="1443" />
                        </StackPanel>

                        <!-- Secret Setting -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Секрет MTProto (32 символа)" FontSize="12" Opacity="0.8" />
                                <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Криптографический ключ для подключения к MTProto прокси. Должен быть длиной ровно 32 шестнадцатеричных символа (hex)." VerticalAlignment="Center" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" x:Name="ProxySecretTextBox" Text="{x:Bind ViewModel.ProxySecretText, Mode=TwoWay}" PlaceholderText="32-значный hex-секрет" />
                                <Button Grid.Column="1" Command="{x:Bind ViewModel.RegenerateSecretCommand}" ToolTipService.ToolTip="Сгенерировать случайный секрет" Height="32">
                                    <TextBlock Text="Новый" FontSize="11" />
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Save Button -->
                        <Button x:Name="SaveSettingsButton" Click="SaveSettingsButton_Click" Content="Сохранить настройки" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Information Card (TgWsProxy C# Native Engine explanation) -->
                <Border Style="{StaticResource GlassCardStyle}" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="О ПРОЕКТЕ И РАЗРАБОТКЕ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Оригинальная идея и проект:" FontWeight="Bold" FontSize="11" Foreground="#A79A83" />
                            <TextBlock Text="Flowseal (автор оригинальной концепции и утилиты tg-ws-proxy)" FontSize="11" Opacity="0.9" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Архитектура C# реализации:" FontWeight="Bold" FontSize="11" Foreground="#A79A83" />
                            <TextBlock Text="Модуль полностью переписан с нуля на асинхронном C# (.NET 10). Внутри GUI работает нативный TcpListener, обрабатывающий MTProto-трафик Telegram, расшифровывающий заголовки (AES-CTR / Fake TLS) и туннелирующий соединение через WebSocket (Cloudflare Workers) или нативный Fake TLS к дата-центрам Telegram (DC1–DC5)." FontSize="11" TextWrapping="Wrap" Opacity="0.8" />
                        </StackPanel>

                        <TextBlock Text="Открытость кода и модули:" FontWeight="Bold" FontSize="11" Foreground="#A79A83" />
                        <TextBlock Text="Работает нативно в процессе C# без Python и внешних скриптов. Исходный код доступен в папке Services/TgWsProxy (TgWsProxyServer, RawWebSocket, FakeTls, AesCtr, Balancer)." FontSize="11" TextWrapping="Wrap" Opacity="0.8" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
