<Page
    x:Class="ZapretMirrlyGUI.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid>
        <TabView x:Name="DiagnosticsTabView" IsAddTabButtonVisible="False" TabWidthMode="SizeToContent">
            <TabView.TabItems>
                <!-- Tab 1: DPI Evasion Strategy Testing -->
                <TabViewItem Header="Тестирование стратегий" IsClosable="False">
                    <TabViewItem.Content>
                        <Grid Padding="{StaticResource PagePadding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="380" />
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: Controls and Terminal Log -->
                            <Grid Grid.Column="0" Margin="0,0,24,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
                                    <TextBlock Text="Тестирование обхода DPI" Style="{StaticResource PremiumPageTitleStyle}" FontSize="22" />
                                    <TextBlock Text="Автоматический прогон пресетов для выявления лучшего способа обхода" Style="{StaticResource PremiumSubtitleStyle}" FontSize="12" />
                                </StackPanel>

                                 <!-- 1. Parameters Control Deck (Transparent with thin dark border) -->
                                <Border Grid.Row="1" x:Name="ControlDeckBorder" Background="Transparent" BorderBrush="#27272A" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                                    <Grid RowSpacing="14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Section Title & ISP Badge -->
                                        <Grid Grid.Row="0">
                                            <TextBlock Text="ПАРАМЕТРЫ ПРОВЕРКИ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                                            <Border HorizontalAlignment="Right" Background="#1E1E22" BorderBrush="#27272A" BorderThickness="1" CornerRadius="6" Padding="10,4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE839;" FontSize="11" Foreground="#A1A1AA" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="IspStatusTextBlock" Text="Провайдер: Определение..." FontSize="11" FontWeight="SemiBold" Foreground="#FAFAFA" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Filter Controls Grid -->
                                        <Grid Grid.Row="1" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="260" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Col 0: Test Type -->
                                            <StackPanel Grid.Column="0" Spacing="6">
                                                <TextBlock Text="Тип проверки" Style="{StaticResource MirrlyTextSmallStyle}" FontSize="11" Foreground="#A1A1AA" />
                                                <ComboBox x:Name="TestTypeComboBox" HorizontalAlignment="Stretch" SelectionChanged="TestTypeComboBox_SelectionChanged" Height="36" CornerRadius="8">
                                                    <ComboBoxItem Content="Стандартный (HTTP)" Tag="standard" IsSelected="True" />
                                                    <ComboBoxItem Content="DPI Checker (TCP)" Tag="dpi" />
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- Col 1: Run Mode & Optional Config Selector -->
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <TextBlock Text="Режим прогона" Style="{StaticResource MirrlyTextSmallStyle}" FontSize="11" Foreground="#A1A1AA" />
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                    <ComboBox Grid.Column="0" x:Name="RunModeComboBox" HorizontalAlignment="Stretch" SelectionChanged="RunModeComboBox_SelectionChanged" Height="36" CornerRadius="8">
                                                        <ComboBoxItem Content="Все пресеты" Tag="all" IsSelected="True" />
                                                        <ComboBoxItem Content="Выборочно" Tag="select" />
                                                    </ComboBox>

                                                    <Button Grid.Column="1" x:Name="SelectConfigsButton" Content="Выбрать" IsEnabled="False" Height="36" CornerRadius="8" Padding="12,0" Background="#27272A" BorderBrush="#3F3F46" Foreground="#FAFAFA">
                                                        <Button.Flyout>
                                                            <Flyout x:Name="ConfigsFlyout" Opened="ConfigsFlyout_Opened" Closed="ConfigsFlyout_Closed">
                                                                <StackPanel Width="260" Spacing="8">
                                                                    <TextBlock Text="Выберите файлы для теста:" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Foreground="#FAFAFA" />
                                                                    <ListView x:Name="ConfigsListView" SelectionMode="None" Height="220">
                                                                        <!-- Populated programmatically -->
                                                                    </ListView>
                                                                </StackPanel>
                                                            </Flyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Col 2: Timeout -->
                                            <StackPanel Grid.Column="2" Spacing="6">
                                                <TextBlock Text="Таймаут" Style="{StaticResource MirrlyTextSmallStyle}" FontSize="11" Foreground="#A1A1AA" />
                                                <ComboBox x:Name="TimeoutComboBox" HorizontalAlignment="Stretch" Height="36" CornerRadius="8">
                                                    <ComboBoxItem Content="2 сек" Tag="2" />
                                                    <ComboBoxItem Content="5 сек" Tag="5" IsSelected="True" />
                                                    <ComboBoxItem Content="10 сек" Tag="10" />
                                                    <ComboBoxItem Content="15 сек" Tag="15" />
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- Col 3: Actions (Play / Stop) -->
                                            <StackPanel Grid.Column="3" Spacing="6" HorizontalAlignment="Left" Margin="8,0,0,0">
                                                <TextBlock Text=" " Style="{StaticResource MirrlyTextSmallStyle}" FontSize="11" Foreground="Transparent" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button x:Name="PlayButton" Click="PlayButton_Click" Style="{StaticResource PremiumAccentButtonStyle}" Height="36" Width="100" CornerRadius="8">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" HorizontalAlignment="Center" Text="Запуск" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#FAFAFA" />
                                                            <ProgressRing Grid.Column="1" x:Name="PlayProgressRing" IsActive="False" Width="16" Height="16" Foreground="White" Margin="6,0,0,0" Visibility="Collapsed" />
                                                        </Grid>
                                                    </Button>

                                                    <Button x:Name="StopButton" Click="StopButton_Click" IsEnabled="False" Height="36" Width="80" CornerRadius="8" Background="#27272A" BorderBrush="#3F3F46" Foreground="#A1A1AA">
                                                        <TextBlock Text="Стоп" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- 2. Terminal Console Log -->
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Console header actions -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10" ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <TextBlock Text="ХОД ПРОВЕРКИ" Style="{StaticResource MirrlyTextMediumStyle}" FontWeight="Bold" Foreground="#FAFAFA" />
                                            <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" VerticalAlignment="Center">
                                                <ToolTipService.ToolTip>
                                                    <ToolTip Background="#1F1F1F" BorderBrush="#333" Foreground="#F3EFE6">
                                                        <StackPanel Spacing="6" Padding="4">
                                                            <TextBlock Text="Цветовой язык журнала:" FontWeight="Bold" FontSize="12" />
                                                            <TextBlock Text="● Красный — Ошибки, сбои, блокировки (ERROR, FAIL, Exception)" Foreground="#FF6B6B" FontSize="11" />
                                                            <TextBlock Text="● Оранжевый — Предупреждения, таймауты (WARNING, Timeout)" Foreground="#FF922B" FontSize="11" />
                                                            <TextBlock Text="● Зеленый — Успешное выполнение, доступность (OK, успешно, success)" Foreground="#51CF66" FontSize="11" />
                                                            <TextBlock Text="● Голубой — Системные действия, команды (CMD, Checking, Запуск)" Foreground="#339AF0" FontSize="11" />
                                                            <TextBlock Text="● Серый — Информационные сообщения (INFO)" Foreground="#ADB5BD" FontSize="11" />
                                                        </StackPanel>
                                                    </ToolTip>
                                                </ToolTipService.ToolTip>
                                            </FontIcon>
                                            <ProgressRing x:Name="StatusProgressRing" IsActive="False" Width="16" Height="16" VerticalAlignment="Center" />
                                            <TextBlock x:Name="StatusStripTextBlock" Text="Готово" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" VerticalAlignment="Center" />
                                        </StackPanel>

                                        <Button Grid.Column="1" x:Name="ViewLogsButton" Click="ViewLogsButton_Click" Height="28" Width="28" Padding="0" Margin="0,0,8,0" ToolTipService.ToolTip="Перейти к журналу логов">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8FD;" FontSize="14" />
                                        </Button>

                                        <Button Grid.Column="2" x:Name="CopyConsoleButton" Click="CopyConsoleButton_Click" Height="28" Width="28" Padding="0" ToolTipService.ToolTip="Копировать лог диагностики в буфер">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="14" />
                                        </Button>
                                    </Grid>

                                    <!-- Terminal viewport -->
                                    <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}" Padding="6" Background="#0C0C0C" BorderBrush="#1F1F1F">
                                        <ScrollViewer x:Name="ConsoleLogScrollViewer" VerticalScrollBarVisibility="Auto">
                                            <RichTextBlock x:Name="ConsoleLogRichTextBlock" IsTextSelectionEnabled="True" FontFamily="Consolas" FontSize="12" Foreground="#F3EFE6" TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- Right Column: Tested Strategies & Summary Pane -->
                            <Grid Grid.Column="1" x:Name="DiagnosticsRightColumn">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 1. Leaderboard Board -->
                                <Border Grid.Row="0" Style="{StaticResource GlassCardStyle}" Padding="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
                                             <StackPanel Orientation="Horizontal" Spacing="8">
                                                 <TextBlock Text="ТАБЛИЦА ЛИДЕРОВ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                                                 <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Сводный рейтинг обхода. Чем выше пресет, тем стабильнее обход на вашей сети. Выберите победителя и примените его кнопкой внизу - стратегия сменится на главной панели." VerticalAlignment="Center" />
                                             </StackPanel>
                                            <TextBlock Text="Оценка работоспособности пресетов:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.6" />
                                        </StackPanel>

                                        <!-- List of strategies and score values -->
                                        <ListView Grid.Row="1" x:Name="StrategyScoresListView" SelectionMode="None">
                                            <ListView.ItemContainerTransitions>
                                                <TransitionCollection>
                                                    <AddDeleteThemeTransition />
                                                    <ReorderThemeTransition />
                                                </TransitionCollection>
                                            </ListView.ItemContainerTransitions>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" Padding="12,10" Background="#14FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8">
                                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                                            <!-- Rank/Medal Glyph -->
                                                            <TextBlock Grid.Column="0" Text="{Binding RankGlyph}" Foreground="{Binding RankColor}" FontSize="18" FontWeight="Bold" Width="32" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,8,0" />

                                                            <!-- Main Preset Data & Progress -->
                                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding ConfigName}" FontWeight="Bold" Style="{StaticResource MirrlyTextSmallStyle}" />
                                                                
                                                                <!-- Dynamic Success Progress Bar -->
                                                                <ProgressBar Value="{Binding SuccessPercent}" Minimum="0" Maximum="100" Height="3" HorizontalAlignment="Stretch" Foreground="{Binding BadgeBackground}" Background="#25FFFFFF" CornerRadius="1" Margin="0,4,0,2" />
                                                                
                                                                <TextBlock Text="{Binding Details}" FontSize="10" Opacity="0.65" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>

                                                            <!-- Pill Badge -->
                                                            <Border Grid.Column="2" Background="{Binding BadgeBackground}" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ScoreText}" Foreground="{Binding BadgeForeground}" FontSize="10" FontWeight="Bold" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Border>

                                 <!-- 2. Clean Neutral Best Strategy Card -->
                                <Border Grid.Row="1" x:Name="BestStrategyCard" Background="#141416" BorderBrush="#27272A" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,16,0,0" Visibility="Collapsed">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="ОПТИМАЛЬНАЯ СТРАТЕГИЯ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A1A1AA" />
                                        <TextBlock x:Name="BestStrategyTextBlock" Text="Не определен" FontWeight="Bold" Style="{StaticResource MirrlyTextMediumStyle}" FontSize="15" />
                                        
                                        <Button x:Name="ApplyBestStrategyButton" Click="ApplyBestStrategyButton_Click" HorizontalAlignment="Stretch" Style="{StaticResource PremiumAccentButtonStyle}" Height="36" CornerRadius="8">
                                            <TextBlock Text="Применить стратегию" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabViewItem.Content>
                </TabViewItem>

                <!-- Tab 2: System Diagnostics (Option 10 parity) -->
                <TabViewItem Header="Системные проверки" IsClosable="False">
                    <TabViewItem.Content>
                        <Grid Padding="{StaticResource PagePadding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="360" />
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: Diagnostic Cards List -->
                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,24,0">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="СОСТОЯНИЕ СИСТЕМЫ ДЛЯ ОБХОДА" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                                    
                                    <!-- BFE Service Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="BfeStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Служба фильтрации Windows (BFE)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Служба безопасности ядра Windows. Управляет сетевыми фильтрами и брандмауэром. Необходима для корректного запуска драйвера WinDivert. Если служба отключена - обход DPI запустить не удастся." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="BfeStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Proxy Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="ProxyStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Системный прокси-сервер" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Проверяет наличие активных системных прокси в Windows. Сторонние прокси или расширения VPN в браузере перехватывают трафик до winws.exe, что делает обход неэффективным." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="ProxyStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- TCP Timestamps Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="TimestampsStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Метки времени TCP (Timestamps)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Служебные маркеры времени в сетевых пакетах. Некоторые провайдеры блокируют измененные winws.exe пакеты с неверными метками. Проверка выявит это и подскажет, если метки нужно отключить." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="TimestampsStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Conflict Services Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="ConflictsStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Конфликтующее ПО и службы" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Поиск запущенных сторонних средств обхода (GoodbyeDPI, другие копии zapret). Одновременный запуск двух утилит приведет к конфликту драйвера WinDivert. Исправьте это кнопкой 'Устранить конфликты ПО' справа." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="ConflictsStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- VPN Services Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="VpnStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="VPN-подключения и адаптеры" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Проверка активных VPN-соединений на компьютере. winws.exe работает напрямую с вашим провайдером. Если включен глобальный VPN, трафик шифруется и идет через него, поэтому локальный обход DPI на него никак не влияет." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="VpnStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Secure DNS Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="DnsStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Безопасный DNS (DoH)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Шифрование запросов к именам сайтов (DNS-over-HTTPS). Защищает от подмены IP-адресов со стороны провайдера. Рекомендуется настроить DoH в браузере или Windows для стабильного обхода." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="DnsStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Hosts File Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="HostsStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Системный файл hosts" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Файл локальной маршрутизации доменов. Проверяет наличие старых записей (например, для YouTube или Discord), которые со временем начинают блокировать доступ к сервисам вместо ускорения." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="HostsStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- WinDivert Card -->
                                    <Border Style="{StaticResource GlassCardStyle}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <FontIcon Grid.Column="0" Glyph="&#xE9CE;" x:Name="DivertStatusIcon" Foreground="Orange" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="Драйвер WinDivert" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Низкоуровневое ядро перехвата сетевых пакетов. Если драйвер заблокирован антивирусом или не загружен из-за отключенной службы BFE, winws.exe не сможет модифицировать пакеты и обходить DPI." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="DivertStatusDetails" Text="Ожидание проверки..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Right Column: Diagnostics Control Panel -->
                            <StackPanel Grid.Column="1" Spacing="20">
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="УПРАВЛЕНИЕ ПРОВЕРКАМИ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                                        <TextBlock Text="Анализ сетевой подсистемы Windows, выявление конфликтующих драйверов, фонового ПО и чистка кэша." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />

                                        <Button x:Name="RunSystemDiagnosticsBtn" Click="RunSystemDiagnosticsBtn_Click" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Stretch" Height="44" Margin="0,8,0,0">
                                             <TextBlock Text="Запустить проверку" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="АВТОМАТИЧЕСКИЕ ДЕЙСТВИЯ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                                        
                                        <Button x:Name="FixSystemConflictsBtn" Click="FixSystemConflictsBtn_Click" HorizontalAlignment="Stretch" Height="38">
                                            <TextBlock Text="Устранить конфликты ПО" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>

                                        <Button x:Name="ClearDiscordCacheBtn" Click="ClearDiscordCacheBtn_Click" HorizontalAlignment="Stretch" Height="38" Margin="0,4,0,0">
                                            <TextBlock Text="Очистить кэш Discord" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- System Log Output -->
                                <Border Style="{StaticResource GlassCardStyle}" Background="#0C0C0C" BorderBrush="#1F1F1F" Height="220" Padding="8">
                                    <TextBox x:Name="SystemDiagnosticsLogTextBox" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" Background="Transparent" BorderThickness="0" Foreground="#F3EFE6" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </TabViewItem.Content>
                </TabViewItem>
            </TabView.TabItems>
        </TabView>
    </Grid>
</Page>
