<Page
    x:Class="ZapretMirrlyGUI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- LEFT COLUMN: Monitor + Log                             -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header with Top-Bar Metrics -->
            <Grid Grid.Row="0" x:Name="DashboardTopHeaderGrid" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Title & Subtitle -->
                <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="DPI обход discord + youtube" Style="{StaticResource PremiumPageTitleStyle}" FontSize="22" />
                    <TextBlock Text="Запуск локального обхода DPI и мониторинг состояния соединения" Style="{StaticResource PremiumSubtitleStyle}" FontSize="12" />
                </StackPanel>

                <!-- Right: Top-Bar Network Latency Metrics -->
                <StackPanel Grid.Column="1" x:Name="TopMetricsPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="YouTube:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.65" FontSize="11" />
                        <TextBlock x:Name="YtPingText" Text="{x:Bind ViewModel.YtPingText, Mode=OneWay}" Foreground="{x:Bind ViewModel.YtPingBrush, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" FontSize="11" />
                    </StackPanel>

                    <TextBlock Text="│" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.3" FontSize="11" VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Discord:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.65" FontSize="11" />
                        <TextBlock x:Name="DcPingText" Text="{x:Bind ViewModel.DcPingText, Mode=OneWay}" Foreground="{x:Bind ViewModel.DcPingBrush, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" FontSize="11" />
                    </StackPanel>

                    <TextBlock Text="│" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.3" FontSize="11" VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Потери:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.65" FontSize="11" />
                        <TextBlock x:Name="LossText" Text="{x:Bind ViewModel.LossText, Mode=OneWay}" Foreground="{x:Bind ViewModel.LossBrush, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ─── CONNECTION MONITOR ─── -->
            <Border Grid.Row="1" x:Name="MonitorCard" Style="{StaticResource GlassCardStyle}" Padding="0" Margin="0,0,0,16" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Top band: Status -->
                    <Grid Grid.Row="0" Padding="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Pulsing status orb -->
                        <Border Grid.Column="0" x:Name="StatusOrbOuter" Width="52" Height="52" CornerRadius="26" Margin="0,0,20,0" VerticalAlignment="Center" Background="{x:Bind ViewModel.StatusOrbBg, Mode=OneWay}">
                            <Border x:Name="StatusOrbInner" Width="34" Height="34" CornerRadius="17" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{x:Bind ViewModel.StatusOrbInnerBg, Mode=OneWay}">
                                <FontIcon x:Name="StatusIndicatorIcon" Glyph="{x:Bind ViewModel.StatusIndicatorIconGlyph, Mode=OneWay}" Foreground="{x:Bind ViewModel.StatusIconFg, Mode=OneWay}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>

                        <!-- Status text -->
                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="МОНИТОР ПОДКЛЮЧЕНИЯ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                                <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#8A8A8F" ToolTipService.ToolTip="Главный переключатель обхода блокировок DPI. Запущен: Трафик к заблокированным сайтам перехватывается и модифицируется. Остановлен: Программа не влияет на пакеты." VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock x:Name="StatusText" Text="{x:Bind ViewModel.StatusTitle, Mode=OneWay}" Style="{StaticResource MirrlyTextLargeStyle}" FontSize="17" FontWeight="Bold" />
                            <TextBlock x:Name="ServiceStatusText" Text="{x:Bind ViewModel.ServiceNote, Mode=OneWay}" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                        </StackPanel>
                    </Grid>

                    <!-- Bottom band: Launch button -->
                    <Grid Grid.Row="1" x:Name="MonitorActionBar" Padding="24,0,24,20">
                        <Button x:Name="ActionBypassButton" Command="{x:Bind ViewModel.ToggleBypassCommand}" IsEnabled="{x:Bind ViewModel.IsActionButtonEnabled, Mode=OneWay}" Style="{StaticResource PremiumAccentButtonStyle}" HorizontalAlignment="Stretch" Height="48">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" HorizontalAlignment="Center" x:Name="ActionBypassText" Text="{x:Bind ViewModel.ActionButtonText, Mode=OneWay}" FontWeight="Bold" Style="{StaticResource MirrlyTextMediumStyle}" VerticalAlignment="Center" />
                                <ProgressRing Grid.Column="1" x:Name="ActionBypassProgressRing" IsActive="{x:Bind ViewModel.IsProgressRingActive, Mode=OneWay}" Visibility="{x:Bind ViewModel.ProgressRingVisibility, Mode=OneWay}" Width="20" Height="20" Foreground="White" Margin="10,0,0,0" />
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- ─── LAUNCH LOG ─── -->
            <Border Grid.Row="2" x:Name="LaunchLogCard" Style="{StaticResource GlassCardStyle}" Background="{ThemeResource ConsoleBackgroundBrush}" BorderBrush="{ThemeResource ConsoleBorderBrush}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Log header -->
                    <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource WidgetCardBackgroundBrush}" BorderBrush="{ThemeResource ConsoleBorderBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9F5;" FontSize="12" Foreground="#A79A83" />
                            <TextBlock Text="ЖУРНАЛ ЗАПУСКА" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                            <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#8A8A8F" ToolTipService.ToolTip="Окно вывода логов утилиты winws.exe. Показывает сообщения о старте, загрузке списков сайтов, перехвате пакетов и ошибках." VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button x:Name="CopyLogButton" Command="{x:Bind ViewModel.CopyLogCommand}" Padding="0" Height="26" Width="26" ToolTipService.ToolTip="Копировать журнал запуска">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="13" />
                            </Button>
                            <Button x:Name="ClearLogButton" Command="{x:Bind ViewModel.ClearLogCommand}" Padding="0" Height="26" Width="26" ToolTipService.ToolTip="Очистить журнал">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" FontSize="13" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Log output -->
                    <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14,10">
                        <TextBlock x:Name="LaunchLogTextBlock" Text="{x:Bind ViewModel.LaunchLogText, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource ConsoleForegroundBrush}" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- RIGHT COLUMN: Strategy Config                          -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Margin="0,80,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" x:Name="StrategyCard" Style="{StaticResource GlassCardStyle}" Padding="20" Margin="0,0,0,16">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="КОНФИГУРАЦИЯ СТРАТЕГИИ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                        <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#8A8A8F" ToolTipService.ToolTip="Выбор сценария (.bat файла) для обхода DPI. Различные провайдеры используют разные алгоритмы фильтрации. Выберите тактику обхода. Рекомендуется запустить тест всех пресетов во вкладке 'Тестирование параметров DPI' — программа проверит все пресеты на вашей сети и выявит лучший!" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Активная стратегия:" Style="{StaticResource MirrlyTextMediumStyle}" FontWeight="SemiBold" />
                        <ComboBox x:Name="PresetComboBox" ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Arguments display card -->
            <Border Grid.Row="1" x:Name="ArgumentsCard" Style="{StaticResource GlassCardStyle}" Padding="0" Background="{ThemeResource ConsoleBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Args header -->
                    <Border Grid.Row="0" Background="{ThemeResource WidgetCardBackgroundBrush}" BorderBrush="{ThemeResource ConsoleBorderBrush}" Padding="14,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE756;" FontSize="12" Foreground="#A79A83" />
                                <TextBlock Text="АРГУМЕНТЫ КОМАНДНОЙ СТРОКИ" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#A79A83" />
                                <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#8A8A8F" ToolTipService.ToolTip="Технические параметры ядра winws.exe. Формируются автоматически на основе выбранного пресета (фильтры портов, списки адресов и методы расщепления пакетов)." VerticalAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="CopyArgsButton" Command="{x:Bind ViewModel.CopyArgsCommand}" Padding="0" Height="26" Width="26" ToolTipService.ToolTip="Копировать аргументы командной строки">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="13" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Args content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14,10">
                        <TextBlock x:Name="PresetArgumentsTextBox" Text="{x:Bind ViewModel.PresetArgumentsText, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource ConsoleForegroundBrush}" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- NOTIFICATION OVERLAY: AUTO-APPLIED BEST STRATEGY        -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid x:Name="DiagnosticRecommendationOverlay" Visibility="{x:Bind ViewModel.OverlayVisibility, Mode=OneWay}" Canvas.ZIndex="999" Margin="-32">
            <!-- Light, non-intrusive backdrop -->
            <Grid Background="#35000000">
                <!-- Acrylic Glass Card Container -->
                <Border Width="580" Height="370" CornerRadius="16" Style="{StaticResource GlassCardStyle}" BorderBrush="#3F3F46" BorderThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="28">
                    <Border.Background>
                        <AcrylicBrush TintColor="#141416" TintOpacity="0.88" FallbackColor="#141416" />
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Spacing="4">
                            <TextBlock Text="АВТОМАТИЧЕСКАЯ НАСТРОЙКА DPI" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="Bold" Foreground="#38BDF8" />
                            <TextBlock Text="Применена лучшая стратегия" FontSize="18" FontWeight="ExtraBold" Foreground="#FAFAFA" Margin="0,2,0,0" />
                            <TextBlock Text="По результатам проведенной диагностики система автоматически активировала оптимальный пресет:" FontSize="12" Foreground="#A1A1AA" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Big Applied Strategy Card -->
                        <Border Grid.Row="1" Background="#1E1E22" BorderBrush="#38BDF8" BorderThickness="1.5" CornerRadius="12" Padding="20" Margin="0,16,0,16" VerticalAlignment="Center">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Победитель диагностики:" FontSize="11" FontWeight="Bold" Foreground="#38BDF8" />
                                    <TextBlock x:Name="OverlayWinnerPresetName" Text="{x:Bind ViewModel.WinnerPresetName, Mode=OneWay}" FontSize="20" FontWeight="Black" Foreground="White" TextWrapping="Wrap" />
                                    <TextBlock x:Name="OverlayWinnerStatsText" Text="{x:Bind ViewModel.WinnerStatsText, Mode=OneWay}" FontSize="12" Foreground="#A1A1AA" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1" Background="#102A1D" BorderBrush="#10B981" BorderThickness="1" Padding="10,6" CornerRadius="8" VerticalAlignment="Center">
                                    <TextBlock Text="Рекомендуется для провайдера" FontSize="10" FontWeight="Bold" Foreground="#10B981" TextWrapping="Wrap" Width="120" TextAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Action Button -->
                        <Button Grid.Row="2" x:Name="ApplyWinnerNowButton" Command="{x:Bind ViewModel.ApplyWinnerNowCommand}" Style="{StaticResource PremiumAccentButtonStyle}" Height="42" HorizontalAlignment="Stretch" CornerRadius="8">
                            <TextBlock x:Name="ApplyWinnerNowButtonText" Text="{x:Bind ViewModel.ApplyWinnerButtonText, Mode=OneWay}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
