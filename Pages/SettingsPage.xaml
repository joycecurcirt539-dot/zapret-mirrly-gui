<Page
    x:Class="ZapretMirrlyGUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid>
        <NavigationView x:Name="SettingsNav"
                        PaneDisplayMode="Left"
                        CompactModeThresholdWidth="0"
                        ExpandedModeThresholdWidth="0"
                        IsPaneToggleButtonVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        SelectionChanged="SettingsNav_SelectionChanged">

            <NavigationView.PaneHeader>
                <StackPanel Margin="16,24,16,18" Spacing="4">
                    <TextBlock Text="Настройки" Style="{StaticResource MirrlyTextLargeStyle}" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="Параметры запуска и обхода" Style="{StaticResource MirrlyTextSmallStyle}" FontSize="11" Opacity="0.8" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.PaneFooter>
                <StackPanel Margin="12,0,12,12" Spacing="8">
                    <Button Click="SaveSettingsButton_Click" HorizontalAlignment="Stretch" Style="{StaticResource PremiumAccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Применить" Style="{StaticResource MirrlyTextMediumStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Click="CancelSettingsButton_Click" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="Отменить изменения" Style="{StaticResource MirrlyTextMediumStyle}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Настройки приложения" Tag="launch" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <!-- Шестеренка настроек для единой вкладки -->
                        <PathIcon Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Фильтры трафика" Tag="filters">
                    <NavigationViewItem.Icon>
                        <!-- Воронка-фильтр -->
                        <PathIcon Data="F1 M3 4 L21 4 L14 13 L14 20 L10 20 L10 13 Z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Папки и файлы" Tag="folders">
                    <NavigationViewItem.Icon>
                        <!-- Папка с вкладкой -->
                        <PathIcon Data="M2 8 Q2 6 4 6 L10 6 L12 8 L20 8 Q22 8 22 10 L22 18 Q22 20 20 20 L4 20 Q2 20 2 18 Z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Обновления" Tag="updates">
                    <NavigationViewItem.Icon>
                        <!-- Стрелка вниз + линия = скачать обновление -->
                        <PathIcon Data="M12 3 L12 15 M7 11 L12 16 L17 11 M4 19 L20 19" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Обход Telegram" Tag="tgwsproxy">
                    <NavigationViewItem.Icon>
                        <!-- Бумажный самолётик Telegram -->
                        <PathIcon Data="M3 12 L21 4 L14 20 L10 14 Z" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
                <Grid>
                    <!-- 1. Launch Parameters Panel -->
                    <StackPanel x:Name="LaunchParamsPanel" Spacing="20" MaxWidth="700" HorizontalAlignment="Left" Visibility="Collapsed">
                        <!-- Card: Acrylic / Mica Backdrop Settings -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Персонализация и эффекты размытия" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                    <FontIcon Glyph="&#xE790;" FontSize="13" Foreground="#A1A1AA" VerticalAlignment="Center" />
                                </StackPanel>

                                <Grid ColumnDefinitions="*, Auto" RowSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Размытие главного окна (Backdrop)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Mica — эффект фоновых обоев (GPU ~0%). Acrylic — матовое стекло (GPU ~5%)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="AppBackdropComboBox" Width="220" SelectionChanged="AppBackdropComboBox_SelectionChanged" VerticalAlignment="Center">
                                        <ComboBoxItem Content="Mica (Рекомендуется)" Tag="Mica" />
                                        <ComboBoxItem Content="Acrylic (Матовое стекло)" Tag="Acrylic" />
                                        <ComboBoxItem Content="Отключить размытие" Tag="None" />
                                    </ComboBox>
                                </Grid>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" />

                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Эффект размытия в трее (Acrylic)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Включает полупрозрачное размытие для меню быстрого управления в системном трее." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" x:Name="TrayBackdropToggle" OnContent="Вкл" OffContent="Выкл" Toggled="TrayBackdropToggle_Toggled" VerticalAlignment="Center" />
                                </Grid>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" />

                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Цветовая тема приложения" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Светлая (светлый графит), Тёмная (глубокий тёмный графит) или Чёрный графит (абсолютно чёрный фон)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" x:Name="AppThemeComboBox" Width="220" SelectionChanged="AppThemeComboBox_SelectionChanged" VerticalAlignment="Center">
                                        <ComboBoxItem Content="Светлая тема" Tag="Light" />
                                        <ComboBoxItem Content="Тёмная тема" Tag="Dark" />
                                        <ComboBoxItem Content="Чёрный графит" Tag="Amoled" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card: Windows Service Management -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE839;" FontSize="14" Foreground="#A1A1AA" VerticalAlignment="Center" />
                                    <TextBlock Text="Служба Windows (Системный автозапуск обхода)" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Установка zapret в виде фоновой службы Windows. Обход работает безотказно и незаметно без необходимости держать открытым GUI." VerticalAlignment="Center" />
                                </StackPanel>

                                <Grid ColumnDefinitions="*, Auto" RowSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Статус службы Windows:" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock x:Name="SettingsServiceStatusText" Text="Проверка статуса..." Style="{StaticResource MirrlyTextSmallStyle}" Foreground="#A1A1AA" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button x:Name="SettingsToggleServiceButton" Click="SettingsToggleServiceButton_Click" Style="{StaticResource PremiumAccentButtonStyle}" Height="36" Padding="14,0" CornerRadius="8">
                                            <TextBlock x:Name="SettingsToggleServiceButtonText" Text="Установить службу" FontWeight="Bold" FontSize="12" />
                                        </Button>

                                        <Button x:Name="SettingsRemoveServiceButton" Click="SettingsRemoveServiceButton_Click" Height="36" Padding="12,0" Background="#27272A" BorderBrush="#3F3F46" CornerRadius="8">
                                            <TextBlock Text="Удалить службу" FontSize="12" Foreground="#F87171" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card: Startup -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Автозапуск приложения при старте Windows" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Автоматический запуск графического интерфейса при входе в Windows. Программа будет запускаться свернутой в трей." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Запуск GUI приложения в свернутом виде при входе пользователя в систему." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="RunAtStartupToggle" OnContent="Да" OffContent="Нет" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Card: Minimize to Tray on Close -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Сворачивать в трей при закрытии" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="При нажатии кнопки закрытия окно скрывается в системный трей, а служба продолжает работать." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="При нажатии кнопки 'Закрыть' приложение сворачивается в область уведомлений." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="MinimizeToTrayOnCloseToggle" OnContent="Да" OffContent="Нет" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Card: Minimize to Tray on Minimize -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Сворачивать в трей при минимизации" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Сворачивание приложения в системный трей вместо панели задач при нажатии кнопки 'Свернуть'." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Перенаправление окна в системный трей при обычном сворачивании." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="MinimizeToTrayOnMinimizeToggle" OnContent="Да" OffContent="Нет" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 2. Packet Filters Panel -->
                    <StackPanel x:Name="FiltersPanel" Spacing="20" MaxWidth="700" HorizontalAlignment="Left" Visibility="Collapsed">
                        <TextBlock Text="Параметры фильтрации трафика" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#FAFAFA" Margin="0,0,0,4" />
                        <TextBlock Text="Настройки правил перехвата и ограничений портов для выборочного обхода DPI." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" Margin="0,0,0,12" />

                        <!-- Interactive Strategy Visual Filtering Map -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Схема фильтрации и перехвата сетевых пакетов" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                <Grid ColumnDefinitions="*, Auto, *, Auto, *, Auto, *" ColumnSpacing="6" Margin="0,8,0,0">
                                    <!-- Block 1: Adapter & IP -->
                                    <Border Grid.Column="0" Padding="8,10" CornerRadius="8" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" Height="90" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <FontIcon Glyph="&#xE774;" FontSize="18" Foreground="#FAFAFA" />
                                            <TextBlock Text="1. Сетевой фильтр" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualFilterInterfaceText" Text="Все адаптеры" FontSize="9" Opacity="0.85" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Arrow 1 -->
                                    <FontIcon Grid.Column="1" Glyph="&#xE72A;" FontSize="14" Foreground="#FAFAFA" Opacity="0.6" VerticalAlignment="Center" />
                                    
                                    <!-- Block 2: Ports / Game filter -->
                                    <Border Grid.Column="2" Padding="8,10" CornerRadius="8" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" Height="90" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <FontIcon x:Name="VisualFilterPortsIcon" Glyph="&#xE9A1;" FontSize="18" Foreground="#FAFAFA" />
                                            <TextBlock Text="2. Порты обхода" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualFilterPortsText" Text="Все порты" FontSize="9" Opacity="0.85" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Arrow 2 -->
                                    <FontIcon Grid.Column="3" Glyph="&#xE72A;" FontSize="14" Foreground="#FAFAFA" Opacity="0.6" VerticalAlignment="Center" />

                                    <!-- Block 3: Site List Matching -->
                                    <Border Grid.Column="4" Padding="8,10" CornerRadius="8" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" Height="90" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <FontIcon x:Name="VisualFilterListIcon" Glyph="&#xE8F1;" FontSize="18" Foreground="#FAFAFA" />
                                            <TextBlock Text="3. База правил" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualFilterListText" Text="Весь интернет" FontSize="9" Opacity="0.85" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Arrow 3 -->
                                    <FontIcon Grid.Column="5" Glyph="&#xE72A;" FontSize="14" Foreground="#FAFAFA" Opacity="0.6" VerticalAlignment="Center" />

                                    <!-- Block 4: Auto Learning status -->
                                    <Border Grid.Column="6" Padding="8,10" CornerRadius="8" Background="#1210B981" BorderBrush="#2510B981" BorderThickness="1" Height="90" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <FontIcon x:Name="VisualFilterLearnIcon" Glyph="&#xEA80;" FontSize="18" Foreground="#10B981" />
                                            <TextBlock Text="4. Автообучение" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualFilterLearnText" Text="Выключено" FontSize="9" Opacity="0.85" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card 1: Game Filter -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Ограничение портов (Игровой фильтр)" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Ограничивает применение обхода только указанными портами (1024-65535). Это необходимо для обхода блокировок голосовых каналов Discord (WebRTC/UDP), но не мешает обычным играм." VerticalAlignment="Center" />
                                </StackPanel>
                                
                                <StackPanel Spacing="12">
                                    <RadioButton x:Name="GameDisabledRadio" Checked="GameRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Полная фильтрация (Отключен)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обход DPI работает абсолютно для всех портов TCP и UDP." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <Border Height="1" Background="{ThemeResource CardBorderBrush}" />
                                    
                                    <RadioButton x:Name="GameAllRadio" Checked="GameRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Игровые TCP и UDP порты (1024 - 65535)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обход для портов от 1024 до 65535 (необходимо для голосовых каналов Discord)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <Border Height="1" Background="{ThemeResource CardBorderBrush}" />
                                    
                                    <RadioButton x:Name="GameTcpRadio" Checked="GameRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Фильтровать только порты TCP (1024+)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обход DPI применяется только для TCP-трафика на портах выше 1024." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <Border Height="1" Background="{ThemeResource CardBorderBrush}" />
                                    
                                    <RadioButton x:Name="GameUdpRadio" Checked="GameRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Фильтровать только порты UDP (1024+)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обход DPI применяется только для UDP-пакетов (WebRTC/Discord Voice)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: IPSet Filter -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Режим списков сайтов (IPSet)" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Ограничивает обход только IP-адресами из файла lists\ipset-all.txt. Полезно, если вы хотите обходить DPI только для конкретного списка сайтов, а не для всего интернета." VerticalAlignment="Center" />
                                </StackPanel>
                                
                                <StackPanel Spacing="12">
                                    <RadioButton x:Name="IpsetLoadedRadio" Checked="IpsetRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Фильтр по спискам IP-адресов" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обходить DPI только для сайтов/IP из файла ipset-all.txt." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <Border Height="1" Background="{ThemeResource CardBorderBrush}" />
                                    
                                    <RadioButton x:Name="IpsetNoneRadio" Checked="IpsetRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Без фильтрации IP-адресов (Весь интернет)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обход DPI применяется ко всем веб-ресурсам и адресам без исключения." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <Border Height="1" Background="{ThemeResource CardBorderBrush}" />
                                    
                                    <RadioButton x:Name="IpsetAnyRadio" Checked="IpsetRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Режим 'Any' (Обход всего, кроме списка исключений)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Применяется для обхода всех заблокированных IP, кроме белых списков." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Auto Hostlist -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Автоматическое обучение списка (Auto Hostlist)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="При сбое соединения с сайтом (сброс, тайм-аут) его домен автоматически заносится в динамический файл lists\autohostlist.txt для последующего обхода." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Автоматическое добавление заблокированных ресурсов в список обхода DPI." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" x:Name="AutoHostlistToggle" OnContent="Вкл" OffContent="Выкл" Toggled="AutoHostlistToggle_Toggled" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Card 4: Bind Network Interface -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Привязка к сетевому интерфейсу" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Позволяет ограничить обход DPI только выбранной сетевой картой (например, только Ethernet или Wi-Fi)." VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Выберите конкретный сетевой интерфейс для обхода (пусто = обход на всех адаптерах)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" />
                                <ComboBox x:Name="BindInterfaceComboBox" HorizontalAlignment="Stretch" SelectionChanged="BindInterfaceComboBox_SelectionChanged" />
                            </StackPanel>
                        </Border>

                        <!-- Card 5: IP Version Protocol -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Фильтрация по протоколам IP" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Ограничивает правила обхода только IPv4 или IPv6 трафиком." VerticalAlignment="Center" />
                                </StackPanel>
                                
                                <StackPanel Spacing="12">
                                    <RadioButton x:Name="IpProtoBothRadio" Checked="IpProtoRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Фильтровать оба протокола (IPv4 и IPv6)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Рекомендуется для полной разблокировки всех типов сетевых соединений." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <Border Height="1" Background="{ThemeResource CardBorderBrush}" />
                                    
                                    <RadioButton x:Name="IpProtoV4Radio" Checked="IpProtoRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Только протокол IPv4" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обход DPI применяется только к IPv4-трафику. IPv6 будет передаваться напрямую." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <Border Height="1" Background="{ThemeResource CardBorderBrush}" />
                                    
                                    <RadioButton x:Name="IpProtoV6Radio" Checked="IpProtoRadio_Checked">
                                        <StackPanel Margin="8,0,0,0" Spacing="2">
                                            <TextBlock Text="Только протокол IPv6" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                            <TextBlock Text="Обход DPI применяется только к IPv6-трафику. IPv4 будет передаваться напрямую." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 3. Files & Folders Panel -->
                    <StackPanel x:Name="FilesFoldersPanel" Spacing="20" MaxWidth="700" HorizontalAlignment="Left" Visibility="Collapsed">
                        <TextBlock Text="Настройки папок и файлов" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#FAFAFA" Margin="0,0,0,4" />
                        <TextBlock Text="Управление рабочими каталогами, списками обхода DPI и созданием резервных копий." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" Margin="0,0,0,12" />

                        <!-- Interactive Storage and Paths Visual Map -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Структура расположения файлов и архивов" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                <Grid ColumnDefinitions="*, Auto, *, Auto, *" ColumnSpacing="8" Margin="0,8,0,0">
                                    <!-- Block 1: Zapret Root path -->
                                    <Border Grid.Column="0" Padding="8,10" CornerRadius="8" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" Height="90" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="18" Foreground="#FAFAFA" />
                                            <TextBlock Text="Корневая папка" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualZapretRootText" Text="Автоопределение" FontSize="9" Opacity="0.85" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Arrow 1 -->
                                    <FontIcon Grid.Column="1" Glyph="&#xE72A;" FontSize="14" Foreground="#FAFAFA" Opacity="0.6" VerticalAlignment="Center" />
                                    
                                    <!-- Block 2: Lists path -->
                                    <Border Grid.Column="2" Padding="8,10" CornerRadius="8" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" Height="90" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <FontIcon Glyph="&#xE8C3;" FontSize="18" Foreground="#FAFAFA" />
                                            <TextBlock Text="Списки доменов" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualListsPathText" Text="zapret\lists" FontSize="9" Opacity="0.85" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Arrow 2 -->
                                    <FontIcon Grid.Column="3" Glyph="&#xE72A;" FontSize="14" Foreground="#FAFAFA" Opacity="0.6" VerticalAlignment="Center" />

                                    <!-- Block 3: Backup folder -->
                                    <Border Grid.Column="4" Padding="8,10" CornerRadius="8" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" Height="90" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <FontIcon Glyph="&#xE949;" FontSize="18" Foreground="#FAFAFA" />
                                            <TextBlock Text="Резервные копии" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualBackupPathText" Text="Не выбрана" FontSize="9" Opacity="0.85" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card 1: Working Folders -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Быстрый переход к файлам" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Быстрый доступ к папкам проекта. Главная папка ведет к исполняемым файлам, а папка списков - к файлам доменов и исключений." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Быстрые кнопки для перехода к папкам утилиты zapret и редактируемым спискам." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button x:Name="OpenRootFolderBtn" Click="OpenRootFolderBtn_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Главная папка" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="OpenListsFolderBtn" Click="OpenListsFolderBtn_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="Папка списков" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card 2: Custom Paths -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Пользовательские папки и пути" FontSize="14" FontWeight="SemiBold" Foreground="#FAFAFA" />
                                        <TextBlock Text="Включите автоопределение путей, чтобы скрыть ручной выбор папок." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" x:Name="AutoPathsToggle" OnContent="Авто" OffContent="Ручной" Toggled="AutoPathsToggle_Toggled" VerticalAlignment="Center" />
                                </Grid>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" Margin="0,2" />
                                
                                <!-- Custom Zapret Binary path -->
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Путь к утилите zapret" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Расположение папки zapret (где находится папка bin с winws.exe). Оставьте пустым для автоопределения." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <TextBox Grid.Column="0" x:Name="CustomZapretRootTextBox" PlaceholderText="Автоопределение (по умолчанию)" IsReadOnly="True" />
                                        <Button Grid.Column="1" x:Name="BrowseZapretRootBtn" Click="BrowseZapretRootBtn_Click">
                                            <TextBlock Text="Обзор..." />
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" Margin="0,4" />

                                <!-- Custom Lists path -->
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Путь к папке списков доменов" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Вы можете указать любую другую папку для списков доменов (например, папку облачного диска для синхронизации)." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <TextBox Grid.Column="0" x:Name="CustomListsPathTextBox" PlaceholderText="Папка 'lists' в корне zapret (по умолчанию)" IsReadOnly="True" />
                                        <Button Grid.Column="1" x:Name="BrowseListsPathBtn" Click="BrowseListsPathBtn_Click">
                                            <TextBlock Text="Обзор..." />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Backup & Restore -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Резервное копирование данных" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#FFCC00" ToolTipService.ToolTip="⚠️ Сначала укажите папку для сохранения резервных копий. Бэкапы будут автоматически создаваться в этой папке." VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Backup path picker -->
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Путь для бэкапов" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Папка, в которую будут записываться ZIP-архивы резервных копий." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <TextBox Grid.Column="0" x:Name="CustomBackupPathTextBox" PlaceholderText="Папка не выбрана" IsReadOnly="True" />
                                        <Button Grid.Column="1" x:Name="BrowseBackupPathBtn" Click="BrowseBackupPathBtn_Click">
                                            <TextBlock Text="Обзор..." />
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" Margin="0,4" />

                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button x:Name="ExportBackupBtn" Click="ExportBackupBtn_Click" Style="{StaticResource PremiumAccentButtonStyle}">
                                        <TextBlock Text="Создать бэкап" />
                                    </Button>
                                    <Button x:Name="ImportBackupBtn" Click="ImportBackupBtn_Click">
                                        <TextBlock Text="Восстановить" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 4. Updates Panel -->
                    <StackPanel x:Name="UpdatesPanel" Spacing="16" MaxWidth="700" HorizontalAlignment="Left" Visibility="Collapsed">
                        <TextBlock Text="Центр обновлений и модулей" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#FAFAFA" Margin="0,0,0,4" />
                        <TextBlock Text="Управление версиями графического интерфейса, утилит обхода DPI и базами фильтрации." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" Margin="0,0,0,12" />

                        <!-- CARD 1: Mirrly GUI -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto" ColumnSpacing="12">
                                <!-- Icon Circle -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE7F4;" FontSize="16" Foreground="#FAFAFA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Text Details -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="4,0,8,0">
                                    <TextBlock Text="Графический интерфейс Mirrly GUI" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                    <TextBlock x:Name="GuiUpdateStatusText" Text="Загрузка версии..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Badge Status -->
                                <Border x:Name="GuiVersionBadge" Grid.Column="2" Width="100" Padding="0,4" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="GuiVersionBadgeText" Text="НЕ ПРОВЕРЕНО" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>

                                <!-- Primary Button -->
                                <Button x:Name="CheckGuiUpdatesBtn" Grid.Column="3" Click="CheckGuiUpdatesBtn_Click" Width="135" Style="{StaticResource PremiumAccentButtonStyle}" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE72C;" FontSize="11" />
                                        <TextBlock Text="Проверить" />
                                    </StackPanel>
                                </Button>

                                <!-- Secondary Button (Placeholder / Collapsed) -->
                                <Border Grid.Column="4" Width="135" Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <!-- CARD 2: winws core -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto" ColumnSpacing="12">
                                <!-- Icon Circle -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE950;" FontSize="16" Foreground="#FAFAFA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Text Details -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="4,0,8,0">
                                    <TextBlock Text="Ядро обхода DPI (winws)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                    <TextBlock x:Name="AppUpdateStatusText" Text="Загрузка версии..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Badge Status -->
                                <Border x:Name="CoreVersionBadge" Grid.Column="2" Width="100" Padding="0,4" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="CoreVersionBadgeText" Text="НЕ ПРОВЕРЕНО" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>

                                <!-- Primary Button -->
                                <Button x:Name="CheckAppUpdatesBtn" Grid.Column="3" Click="CheckAppUpdatesBtn_Click" Width="135" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE72C;" FontSize="11" />
                                        <TextBlock Text="Проверить" />
                                    </StackPanel>
                                </Button>

                                <!-- Secondary Button -->
                                <HyperlinkButton x:Name="DownloadLatestReleaseBtn" Grid.Column="4" Content="Скачать" Width="135" Visibility="Collapsed" VerticalAlignment="Center" HorizontalContentAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- CARD 3: IPSet Database -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto" ColumnSpacing="12">
                                <!-- Icon Circle -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8F1;" FontSize="16" Foreground="#FAFAFA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Text Details -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="4,0,8,0">
                                    <TextBlock Text="База IP-адресов (ipset-all.txt)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                    <TextBlock x:Name="IPSetUpdateStatusText" Text="Проверка базы..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Badge Status -->
                                <Border x:Name="IpsetVersionBadge" Grid.Column="2" Width="100" Padding="0,4" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="IpsetVersionBadgeText" Text="НЕ ПРОВЕРЕНО" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>

                                <!-- Primary Button -->
                                <Button x:Name="UpdateIPSetListBtn" Grid.Column="3" Click="UpdateIPSetListBtn_Click" Width="135" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE896;" FontSize="11" />
                                        <TextBlock Text="Обновить базу" />
                                    </StackPanel>
                                </Button>

                                <!-- Secondary Button (Placeholder / Collapsed) -->
                                <Border Grid.Column="4" Width="135" Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <!-- CARD 4: Hosts File -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto" ColumnSpacing="12">
                                <!-- Icon Circle -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE7C1;" FontSize="16" Foreground="#FAFAFA" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Text Details -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="4,0,8,0">
                                    <TextBlock Text="Системный файл hosts" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                    <TextBlock x:Name="HostsUpdateStatusText" Text="Проверка hosts..." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                </StackPanel>
                                
                                <!-- Badge Status -->
                                <Border x:Name="HostsVersionBadge" Grid.Column="2" Width="100" Padding="0,4" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="HostsVersionBadgeText" Text="НЕ ПРОВЕРЕНО" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>

                                <!-- Primary Button -->
                                <Button x:Name="CheckHostsBtn" Grid.Column="3" Click="CheckHostsBtn_Click" Width="135" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE72C;" FontSize="11" />
                                        <TextBlock Text="Проверить" />
                                    </StackPanel>
                                </Button>

                                <!-- Secondary Button -->
                                <Button x:Name="ApplyHostsUpdateBtn" Grid.Column="4" Click="ApplyHostsUpdateBtn_Click" Width="135" Style="{StaticResource PremiumAccentButtonStyle}" Visibility="Collapsed" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE73E;" FontSize="11" />
                                        <TextBlock Text="Применить" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Card 5: Auto-Update Settings -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Параметры автоматического обновления" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                                        <TextBlock Text="Автопроверка обновлений интерфейса" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Автоматически искать новые версии Mirrly GUI при запуске." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" x:Name="AutoCheckGuiUpdatesToggle" OnContent="Вкл" OffContent="Выкл" VerticalAlignment="Center" />
                                </Grid>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                                        <TextBlock Text="Автопроверка обновлений ядра winws" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Автоматически проверять наличие свежих версий утилиты обхода." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" x:Name="AutoUpdateToggle" OnContent="Вкл" OffContent="Выкл" VerticalAlignment="Center" />
                                </Grid>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                                        <TextBlock Text="Автообновление списков IP-адресов" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Автоматически скачивать актуальную базу IP-адресов при каждом запуске программы." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" x:Name="AutoUpdateDatabaseToggle" OnContent="Вкл" OffContent="Выкл" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 5. TgWsProxy Advanced Panel -->
                    <StackPanel x:Name="TgWsProxyPanel" Spacing="20" MaxWidth="700" HorizontalAlignment="Left" Visibility="Collapsed">
                        <TextBlock Text="Обход блокировок Telegram (TgWsProxy)" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#FAFAFA" Margin="0,0,0,4" />
                        <TextBlock Text="Параметры встроенного транспортного прокси-сервера для стабильной связи Telegram в обход DPI." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" Margin="0,0,0,12" />

                        <!-- Interactive Strategy Visual Map -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Визуальная схема маршрутизации трафика" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                <Grid ColumnDefinitions="*, Auto, *, Auto, *" ColumnSpacing="8" Margin="0,8,0,0">
                                    <!-- Block 1: Telegram Client -->
                                    <Border Grid.Column="0" Padding="12,14" CornerRadius="10" Background="#120088CC" BorderBrush="#250088CC" BorderThickness="1" Height="95" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="6">
                                            <FontIcon Glyph="&#xE724;" FontSize="22" Foreground="#0088CC" />
                                            <TextBlock Text="Клиент Telegram" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock Text="Запросы" FontSize="11" Opacity="0.85" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Arrow 1 -->
                                    <FontIcon Grid.Column="1" Glyph="&#xE72A;" FontSize="18" Foreground="#FAFAFA" Opacity="0.6" VerticalAlignment="Center" />
                                    
                                    <!-- Block 2: TgWsProxy Local Server -->
                                    <Border Grid.Column="2" Padding="12,14" CornerRadius="10" Background="{ThemeResource BrandAlphaBackground}" BorderBrush="{ThemeResource BrandAlphaBorder}" BorderThickness="1" Height="95" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="6">
                                            <FontIcon Glyph="&#xE8F1;" FontSize="22" Foreground="#FAFAFA" />
                                            <TextBlock Text="Локальный прокси" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualProxyPortText" Text="Порт: 1443" FontSize="11" Opacity="0.85" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Arrow 2 -->
                                    <FontIcon Grid.Column="3" Glyph="&#xE72A;" FontSize="18" Foreground="#FAFAFA" Opacity="0.6" VerticalAlignment="Center" />

                                    <!-- Block 3: Exit Nodes -->
                                    <Border Grid.Column="4" Padding="12,14" CornerRadius="10" Background="#1210B981" BorderBrush="#2510B981" BorderThickness="1" Height="95" VerticalAlignment="Center">
                                        <StackPanel VerticalAlignment="Center" Spacing="6">
                                            <FontIcon x:Name="VisualExitNodeIcon" Glyph="&#xE909;" FontSize="22" Foreground="#10B981" />
                                            <TextBlock x:Name="VisualExitNodeTitle" Text="Cloudflare Workers" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="VisualExitNodeDesc" Text="Туннель WebSocket" FontSize="11" Opacity="0.85" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card 1: Connection Setup (Host only) -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Параметры локального прокси-сервера" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />
                                
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Интерфейс прослушивания (Хост)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="IP-адрес для прослушивания (127.0.0.1 = только этот ПК; 0.0.0.0 = вся локальная сеть)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="SettingsProxyHostTextBox" Width="120" PlaceholderText="127.0.0.1" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Cloud Tunneling and Workers -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Облачная интеграция (Cloud Tunneling)" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                                        <TextBlock Text="Маршрутизация через Cloudflare Workers" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Использовать проксирующие Workers для обхода блокировок серверов Telegram." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" x:Name="SettingsCfProxyToggle" OnContent="Вкл" OffContent="Выкл" Toggled="SettingsCfProxyToggle_Toggled" VerticalAlignment="Center" />
                                </Grid>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" />

                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Адреса Cloudflare Workers" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Список доменов ваших Workers (например, worker1.name.workers.dev). Разделяйте запятыми." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBox x:Name="SettingsProxyWorkerDomainsTextBox" PlaceholderText="Например: my-worker.workers.dev, another..." />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Traffic Masking & Advanced Tuning -->
                        <Border Style="{StaticResource GlassCardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Маскировка трафика и оптимизация" FontSize="14" FontWeight="Bold" Foreground="#FAFAFA" />

                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Домен маскировки Fake TLS (SNI)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#8A8A8F" ToolTipService.ToolTip="Хост для маскировки под разрешенный TLS-сайт (например, google.com). Помогает обходить блокировку протокола MTProto провайдером." VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBox x:Name="SettingsProxyFakeTlsDomainTextBox" PlaceholderText="Например: google.com (пусто = без маскировки)" />
                                </StackPanel>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" />

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Размер пула веб-сокетов (Pool Size)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Количество параллельных фоновых соединений для ускорения отклика." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" x:Name="SettingsProxyPoolSizeTextBox" Width="100" PlaceholderText="4" VerticalAlignment="Center" />
                                </Grid>

                                <Border Height="1" Background="{ThemeResource CardBorderBrush}" />

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                                        <TextBlock Text="Принудительное использование тестовых серверов (Test DCs)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextMediumStyle}" />
                                        <TextBlock Text="Использовать исключительно тестовые дата-центры Telegram. Не используйте с обычными аккаунтами." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" x:Name="SettingsProxyForceTestDcToggle" OnContent="Да" OffContent="Нет" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </NavigationView>
    </Grid>
</Page>
