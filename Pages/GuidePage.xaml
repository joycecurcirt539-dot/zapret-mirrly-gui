                            <TextBlock Text="Для обновления встроенной утилиты zapret (базовая версия в сборке: 1.9.9d) выполните следующие шаги:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />

                            <StackPanel Spacing="10" Margin="0,2,0,0">
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="1" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Перейдите по ссылке на официальный репозиторий утилиты zapret на GitHub (кнопка слева внизу)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="2" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Скачайте ZIP-архив новой версии релиза (например, zapret-discord-youtube-1.9.9d.zip)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="3" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Распакуйте скачанную папку и положите её прямо рядом с файлом ZapretMirrlyGUI.exe." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="4" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Переименуйте распакованную папку (например, 'zapret-discord-youtube-1.9.9d') в простое имя zapret (если там уже была старая папка zapret, замените её)." Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="SemiBold" Opacity="0.9" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
