<Page
    x:Class="ZapretMirrlyGUI.Pages.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ══════════════════════ HEADER WITH GRADIENT TITLE ══════════════════════ -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
                <TextBlock Text="Безопасность, Доверие и Справка" Style="{StaticResource PremiumPageTitleStyle}" FontSize="24">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F6F2EA" Offset="0.0" />
                            <GradientStop Color="#D6CDBC" Offset="0.5" />
                            <GradientStop Color="#A79A83" Offset="1.0" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock Text="Важная информация об открытом исходном коде, защите данных и ручном обновлении" Style="{StaticResource PremiumSubtitleStyle}" FontSize="12" />
            </StackPanel>

            <!-- ══════════════════════ SPLIT LAYOUT ══════════════════════ -->
            <Grid Grid.Row="1" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="480" />
                </Grid.ColumnDefinitions>

                <!-- ─────────────────── LEFT COLUMN: Safety, Trust & Disclaimer ─────────────────── -->
                <StackPanel Grid.Column="0" Spacing="16">
                    
                    <!-- Card 1: Warning (Beware of scammers) -->
                    <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="20" Background="#08D19A66" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#D19A66" Offset="0.0" />
                                <GradientStop Color="#8C663D" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="#2B1F17" BorderBrush="#543C28" BorderThickness="1">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="16" Foreground="#D19A66" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Остерегайтесь мошеннических сборок!" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#D19A66" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Обход DPI — это сфера повышенного риска. В сети (особенно в Telegram-каналах и на сомнительных форумах) распространяются десятки «модифицированных» версий утилиты zapret. Многие из них содержат скрытые вирусы, стилеры паролей и майнеры. Скачивая файлы из непроверенных источников, вы рискуете личными переписками, игровыми аккаунтами и банковскими данными." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />
                            <TextBlock Text="Никогда не запускайте исполняемые файлы (.exe) или скрипты (.bat), полученные из недостоверных источников!" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="SemiBold" Opacity="0.95" Foreground="#D19A66" />
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Trust & Transparency -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3E3B35" Offset="0.0" />
                                <GradientStop Color="#1F1E1C" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="#21201E" BorderBrush="#3A3834" BorderThickness="1">
                                    <FontIcon Glyph="&#xE730;" FontSize="16" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Политика доверия: Доверяй, но проверяй" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            
                            <TextBlock Text="Правило безопасности номер один в мире программного обеспечения: не верьте никому на слово — в том числе и мне, разработчику Mirrly GUI. Единственная гарантия чистоты софта — это полностью открытый исходный код (Open Source)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />
                            
                            <TextBlock Text="• Оригинальный zapret: Это надежный проект с полностью открытым исходным кодом. Он абсолютно прозрачен для аудита." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                            <TextBlock Text="• Оболочка Mirrly GUI: Исходный код этой графической программы также полностью открыт на GitHub. Любой независимый программист может проверить каждую строчку, скомпилировать приложение самостоятельно и убедиться, что в нем нет никаких скрытых угроз." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                            <TextBlock Text="• Архитектура: Создание Mirrly GUI — это моя личная инициатива, основанная на желании сделать использование открытых инструментов обхода DPI максимально удобным и простым для каждого пользователя через красивый графический интерфейс." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Card 3: Hope & Open Source -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3E3B35" Offset="0.0" />
                                <GradientStop Color="#1F1E1C" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="#21201E" BorderBrush="#3A3834" BorderThickness="1">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="16" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Свобода, созданная сообществом" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Открытая разработка возвращает контроль над технологиями в руки пользователей. Пока крупные корпорации закрывают свои исходные коды и вводят ограничения, независимые разработчики объединяются, чтобы дарить людям свободу общения без цензуры, сторонних VPN-серверов и скрытых подписок. Проекты, подобные оригинальному zapret, доказывают: сила интернета — в децентрализации, прозрачности и взаимопомощи. Вместе мы делаем сеть безопаснее и доступнее для каждого." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Card 4: Disclaimer (Отказ от ответственности) -->
                    <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="20" Background="#05FFFFFF" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5A524A" Offset="0.0" />
                                <GradientStop Color="#2C2825" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="#211E1C" BorderBrush="#4A3F35" BorderThickness="1">
                                    <FontIcon Glyph="&#xF22A;" FontSize="16" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Отказ от ответственности" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#C0B49F" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Возможность подключения сторонней локальной папки &quot;zapret&quot; создана исключительно для удобства продвинутых пользователей. Автор Mirrly GUI не имеет никакого отношения к сторонним форкам и модификациям оригинальной утилиты, не тестирует их сборки и не несет абсолютно никакой ответственности за стабильность работы вашей системы, безопасность ПК или возможную кражу ваших данных при ручной установке и подмене файлов. Вся ответственность за проверку сторонних бинарников ложится целиком на вас." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Grid.Column="0" Click="OpenOriginalZapretGithub_Click" Style="{StaticResource PremiumAccentButtonStyle}" Height="42" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEE40;" FontSize="14" />
                                <TextBlock Text="GitHub bolvan (zapret)" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Click="OpenMirrlyGithub_Click" Height="42" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEE40;" FontSize="14" />
                                <TextBlock Text="GitHub Mirrly GUI" />
                            </StackPanel>
                        </Button>
                    </Grid>

                </StackPanel>

                <!-- ─────────────────── RIGHT COLUMN: Mechanics & Styled Guide ─────────────────── -->
                <StackPanel Grid.Column="1" Spacing="16">
                    
                    <!-- Card 5: Why Manual Updates? -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3E3B35" Offset="0.0" />
                                <GradientStop Color="#1F1E1C" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="#21201E" BorderBrush="#3A3834" BorderThickness="1">
                                    <FontIcon Glyph="&#xE943;" FontSize="16" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Почему обновление ручное?" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            
                            <TextBlock Text="Реализовать скрытое фоновое автообновление утилит обхода в один клик крайне сложно и небезопасно по следующим техническим причинам:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />

                            <StackPanel Spacing="10" Margin="4,4,0,0">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="1. Системные блокировки файлов" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                    <TextBlock Text="Утилита winws.exe и драйвер WinDivert работают на системном уровне как служба Windows. Во время работы файлы заблокированы ОС. Чтобы их заменить, нужно принудительно останавливать службу, выгружать драйвер из ядра системы, перезаписывать файлы и переустанавливать всё заново." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" TextWrapping="Wrap" />
                                </StackPanel>
                                
                                <StackPanel Spacing="2">
                                    <TextBlock Text="2. Права администратора (UAC)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                    <TextBlock Text="Любые манипуляции с системными службами и сетевыми драйверами требуют повышенных прав администратора. Скрытое автообновление постоянно вызывало бы назойливые системные окна запроса прав UAC." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="3. Риск безопасности автоматической загрузки" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                    <TextBlock Text="Если бы приложение умело само скачивать исполняемые (.exe) файлы из сети и запускать их с правами администратора, это создало бы потенциальную брешь (уязвимость RCE). Ручной контроль гарантирует, что вы точно знаете, какие файлы запускаются на вашем ПК." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="4. Риск несовместимости версий" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                    <TextBlock Text="Если разработчики утилиты изменят формат запуска, аргументы командной строки или структуру конфигураций в новой версии, автоматический запуск старого GUI на новой утилите сломает всю систему. Ручная замена позволяет вам легко контролировать совместимость." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.75" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card 6: Step-by-Step Guide with Plaquettes -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3E3B35" Offset="0.0" />
                                <GradientStop Color="#1F1E1C" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="#21201E" BorderBrush="#3A3834" BorderThickness="1">
                                    <FontIcon Glyph="&#xE897;" FontSize="16" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Инструкция по ручному обновлению" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            
                            <TextBlock Text="Для обновления встроенной утилиты zapret (базовая версия в сборке: 1.9.9a) выполните следующие шаги:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />
                            
                            <StackPanel Spacing="10" Margin="4,4,0,0">
                                
                                <Grid ColumnDefinitions="32,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="#2D2B28" BorderBrush="#47443E" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <TextBlock Text="1" FontSize="11" FontWeight="SemiBold" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Перейдите по ссылке на официальный репозиторий утилиты zapret на GitHub (кнопка слева внизу)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="32,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="#2D2B28" BorderBrush="#47443E" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <TextBlock Text="2" FontSize="11" FontWeight="SemiBold" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Скачайте ZIP-архив новой версии релиза (например, zapret-discord-youtube-1.9.9d.zip)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="32,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="#2D2B28" BorderBrush="#47443E" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <TextBlock Text="3" FontSize="11" FontWeight="SemiBold" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Распакуйте скачанную папку и положите её прямо рядом с файлом ZapretMirrlyGUI.exe." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="32,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="#2D2B28" BorderBrush="#47443E" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <TextBlock Text="4" FontSize="11" FontWeight="SemiBold" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Переименуйте распакованную папку (например, 'zapret-discord-youtube-1.9.9d') в простое имя zapret (если там уже была старая папка zapret, замените её)." Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="SemiBold" Opacity="0.9" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="32,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="#2D2B28" BorderBrush="#47443E" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <TextBlock Text="5" FontSize="11" FontWeight="SemiBold" Foreground="#A79A83" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Полностью закройте приложение (выйдите из системного трея) и запустите его заново. GUI автоматически обнаружит локальную папку zapret рядом с собой и начнет использовать новые файлы!" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.85" TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>

                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
