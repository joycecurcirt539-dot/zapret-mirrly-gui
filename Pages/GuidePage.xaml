<Page
    x:Class="ZapretMirrlyGUI.Pages.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Transitions>
        <TransitionCollection>
            <NavigationThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ══════════════════════ HEADER ══════════════════════ -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
                <TextBlock Text="Безопасность, Доверие и Справка" Style="{StaticResource PremiumPageTitleStyle}" FontSize="24" Foreground="{ThemeResource TitleTextGradientBrush}" />
                <TextBlock Text="Важная информация об открытом исходном коде, защите данных и ручном обновлении" Style="{StaticResource PremiumSubtitleStyle}" FontSize="12" />
            </StackPanel>

            <!-- ══════════════════════ 3-COLUMN LAYOUT ══════════════════════ -->
            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ─────────────── COLUMN 1: Warning + Open Source + Links ─────────────── -->
                <StackPanel Grid.Column="0" Spacing="12">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="30" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <!-- Card 1: Scam Warning (amber accent) -->
                    <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="18" Background="#0AD19A66" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D19A66" Offset="0.0" />
                                <GradientStop Color="#8C663D" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" BorderThickness="1.5">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B2211" Offset="0.0" />
                                            <GradientStop Color="#2B1A0E" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#D19A66" Offset="0.0" />
                                            <GradientStop Color="#8C663D" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <!-- Треугольник опасности -->
                                            <Path Data="M12 3 L21.5 20 L2.5 20 Z M12 9 L12 14" Stroke="#D19A66" StrokeThickness="2.5" Fill="Transparent" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Ellipse Canvas.Left="11" Canvas.Top="15.5" Width="2" Height="2" Fill="#D19A66"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Остерегайтесь мошеннических сборок!" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#D19A66" VerticalAlignment="Center" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Text="Обход DPI — это сфера повышенного риска. В сети (особенно в Telegram-каналах и на сомнительных форумах) распространяются десятки «модифицированных» версий утилиты zapret. Многие из них содержат скрытые вирусы, стилеры паролей и майнеры. Скачивая файлы из непроверенных источников, вы рискуете личными переписками, игровыми аккаунтами и банковскими данными." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />
                            <!-- Highlighted warning callout -->
                            <Border CornerRadius="6" Padding="10,8" Background="#18D19A66">
                                <Grid ColumnDefinitions="16,*" ColumnSpacing="8">
                                    <Viewbox Grid.Column="0" Width="12" Height="12" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M12 3 L21.5 20 L2.5 20 Z M12 9 L12 14" Stroke="#D19A66" StrokeThickness="2.5" Fill="Transparent" StrokeLineJoin="Round"/>
                                            <Ellipse Canvas.Left="11" Canvas.Top="15.5" Width="2" Height="2" Fill="#D19A66"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Grid.Column="1" Text="Никогда не запускайте исполняемые файлы (.exe) или скрипты (.bat), полученные из недостоверных источников!" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="SemiBold" Foreground="#D19A66" TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Card 3: Open Source Community -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1.5">
                                    <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <!-- Три узла-круга соединеные линиями -->
                                            <Ellipse Canvas.Left="9.5" Canvas.Top="2" Width="5" Height="5" Fill="#A79A83"/>
                                            <Ellipse Canvas.Left="2" Canvas.Top="17" Width="5" Height="5" Fill="#A79A83"/>
                                            <Ellipse Canvas.Left="17" Canvas.Top="17" Width="5" Height="5" Fill="#A79A83"/>
                                            <Line X1="12" Y1="7" X2="4.5" Y2="17" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="12" Y1="7" X2="19.5" Y2="17" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="4.5" Y1="19.5" X2="19.5" Y2="19.5" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Свобода, созданная сообществом" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Открытая разработка возвращает контроль над технологиями в руки пользователей. Пока крупные корпорации закрывают свои исходные коды и вводят ограничения, независимые разработчики объединяются, чтобы дарить людям свободу общения без цензуры, сторонних VPN-серверов и скрытых подписок. Проекты, подобные оригинальному zapret, доказывают: сила интернета — в децентрализации, прозрачности и взаимопомощи. Вместе мы делаем сеть безопаснее и доступнее для каждого." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <TextBlock Text="Ссылки на доверенные проекты:" Style="{StaticResource MirrlyTextSmallStyle}" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Button Grid.Row="0" Grid.Column="0" Click="OpenOriginalZapretGithub_Click" Height="38" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="bol-van (zapret)" FontSize="11" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="1" Click="OpenFlowsealGithub_Click" Height="38" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="Flowseal (сборки)" FontSize="11" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="0" Click="OpenGoodbyeDpiGithub_Click" Height="38" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="ValdikSS (GoodbyeDPI)" FontSize="11" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="1" Click="OpenWinDivertGithub_Click" Height="38" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="basil00 (WinDivert)" FontSize="11" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Click="OpenMirrlyGithub_Click" Height="38" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="Исходный код Mirrly GUI на GitHub" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                </StackPanel>

                <!-- ─────────────── COLUMN 2: Trust + Disclaimer ─────────────── -->
                <StackPanel Grid.Column="1" Spacing="12">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="45" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <!-- Card 2: Trust & Transparency -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1.5">
                                    <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <!-- Навесной замок -->
                                            <Path Data="M8 12 Q8 5 12 5 Q16 5 16 12" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Rectangle Canvas.Left="5" Canvas.Top="12" Width="14" Height="10" RadiusX="2" RadiusY="2" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="2" Fill="Transparent"/>
                                            <Ellipse Canvas.Left="10.5" Canvas.Top="15" Width="3" Height="3" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Line X1="12" Y1="18" X2="12" Y2="20" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Политика доверия: Доверяй, но проверяй" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="Правило безопасности номер один в мире программного обеспечения: не верьте никому на слово — в том числе и мне, разработчику Mirrly GUI. Единственная гарантия чистоты софта — это полностью открытый исходный код (Open Source)." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />

                            <!-- Bullet list with icons -->
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="14,*" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0" Width="4" Height="4" Fill="#A79A83" VerticalAlignment="Top" Margin="5,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="bol-van (original zapret): Создатель оригинального движка обхода блокировок DPI, ставшего стандартом прозрачности и эффективности." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnDefinitions="14,*" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0" Width="4" Height="4" Fill="#A79A83" VerticalAlignment="Top" Margin="5,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="Flowseal (сборки и прокси): Разработчик популярных конфигураций zapret-discord-youtube и прокси tg-ws-proxy, сделавший обход доступным широкой аудитории." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnDefinitions="14,*" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0" Width="4" Height="4" Fill="#A79A83" VerticalAlignment="Top" Margin="5,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="ValdikSS (GoodbyeDPI): Легендарный исследователь сетевых технологий в РФ и автор утилиты GoodbyeDPI." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnDefinitions="14,*" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0" Width="4" Height="4" Fill="#A79A83" VerticalAlignment="Top" Margin="5,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="basil00 (WinDivert): Автор мощного драйвера перехвата сетевых пакетов ядра Windows, используемого в GoodbyeDPI и zapret." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnDefinitions="14,*" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0" Width="4" Height="4" Fill="#A79A83" VerticalAlignment="Top" Margin="5,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="Оболочка Mirrly GUI: Исходный код этой графической программы также полностью открыт на GitHub. Любой независимый программист может проверить каждую строчку, скомпилировать приложение самостоятельно и убедиться, что в нем нет никаких скрытых угроз." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </Grid>
                                <Grid ColumnDefinitions="14,*" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0" Width="4" Height="4" Fill="#A79A83" VerticalAlignment="Top" Margin="5,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="Архитектура: Создание Mirrly GUI — это моя личная инициатива, основанная на желании сделать использование открытых инструментов обхода DPI максимально удобным и простым для каждого пользователя через красивый графический интерфейс." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card 4: Disclaimer -->
                    <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="20" Background="#05FFFFFF" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5A524A" Offset="0.0" />
                                <GradientStop Color="#2C2825" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="#211E1C" BorderBrush="#4A3F35" BorderThickness="1.5">
                                    <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <!-- Документ со сложенным уголком + ! -->
                                            <Path Data="M5 2 L5 22 L19 22 L19 7 L14 2 Z M14 2 L14 7 L19 7" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Round"/>
                                            <Line X1="12" Y1="10" X2="12" Y2="15" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Ellipse Canvas.Left="11" Canvas.Top="16.5" Width="2" Height="2" Fill="#A79A83"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Отказ от ответственности" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" Foreground="#C0B49F" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Возможность подключения сторонней локальной папки &quot;zapret&quot; создана исключительно для удобства продвинутых пользователей. Автор Mirrly GUI не имеет никакого отношения к сторонним форкам и модификациям оригинальной утилиты, не тестирует их сборки и не несет абсолютно никакой ответственности за стабильность работы вашей системы, безопасность ПК или возможную кражу ваших данных при ручной установке и подмене файлов. Вся ответственность за проверку сторонних бинарников ложится целиком на вас." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ─────────────── COLUMN 3: Why Manual + Guide ─────────────── -->
                <StackPanel Grid.Column="2" Spacing="12">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" FromVerticalOffset="60" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <!-- Card 5: Why Manual Updates -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1.5">
                                    <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <!-- Круговая стрелка обновления -->
                                            <Path Data="M17 12 Q17 17 12 17 Q7 17 7 12 Q7 7 12 7 Q15 7 17 9" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Path Data="M17 6 L17 9 L14 9" Stroke="{ThemeResource BrandElectricBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Почему обновление ручное?" FontWeight="SemiBold" Style="{StaticResource MirrlyTextLargeStyle}" VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="Реализовать скрытое фоновое автообновление утилит обхода в один клик крайне сложно и небезопасно по следующим техническим причинам:" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" TextWrapping="Wrap" />

                            <StackPanel Spacing="10" Margin="0,2,0,0">
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="1" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Системные блокировки файлов" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                        <TextBlock Text="Утилита winws.exe и драйвер WinDivert работают на системном уровне как служба Windows. Во время работы файлы заблокированы ОС. Чтобы их заменить, нужно принудительно останавливать службу, выгружать драйвер из ядра системы, перезаписывать файлы и переустанавливать всё заново." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="2" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Права администратора (UAC)" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                        <TextBlock Text="Любые манипуляции с системными службами и сетевыми драйверами требуют повышенных прав администратора. Скрытое автообновление постоянно вызывало бы назойливые системные окна запроса прав UAC." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="3" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Риск безопасности автоматической загрузки" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                        <TextBlock Text="Если бы приложение умело само скачивать исполняемые (.exe) файлы из сети и запускать их с правами администратора, это создало бы потенциальную брешь (уязвимость RCE). Ручной контроль гарантирует, что вы точно знаете, какие файлы запускаются на вашем ПК." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="26,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="{ThemeResource IconBorderBackground}" BorderBrush="{ThemeResource IconBorderBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock Text="4" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource BrandElectricBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Риск несовместимости версий" FontWeight="SemiBold" Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.9" />
                                        <TextBlock Text="Если разработчики утилиты изменят формат запуска, аргументы командной строки или структуру конфигураций в новой версии, автоматический запуск старого GUI на новой утилите сломает всю систему. Ручная замена позволяет вам легко контролировать совместимость." Style="{StaticResource MirrlyTextSmallStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Card 6: Step-by-Step Guide -->
                    <Border Style="{StaticResource GlassCardStyle}">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
