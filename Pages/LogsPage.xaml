<Page
    x:Class="ZapretMirrlyGUI.Pages.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid Padding="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Журнал логов" Style="{StaticResource PremiumPageTitleStyle}" FontSize="22" />
                <TextBlock Text="Просмотр и фильтрация системного вывода процессов обхода DPI" Style="{StaticResource PremiumSubtitleStyle}" FontSize="12" />
            </StackPanel>
            <FontIcon Grid.Column="1" Glyph="&#xE946;" FontSize="16" Foreground="#8A8A8F" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <ToolTipService.ToolTip>
                    <ToolTip Background="#1F1F1F" BorderBrush="#333" Foreground="#F3EFE6">
                        <StackPanel Spacing="6" Padding="4">
                            <TextBlock Text="Цветовой язык журнала логов:" FontWeight="Bold" FontSize="12" />
                            <TextBlock Text="● Красный — Ошибки, сбои, блокировки (ERROR, FAIL, Exception)" Foreground="#FF6B6B" FontSize="11" />
                            <TextBlock Text="● Оранжевый — Предупреждения, таймауты (WARNING, Timeout)" Foreground="#FF922B" FontSize="11" />
                            <TextBlock Text="● Зеленый — Успешное выполнение, доступность (OK, успешно, success)" Foreground="#51CF66" FontSize="11" />
                            <TextBlock Text="● Голубой — Системные действия, команды (CMD, Checking, Запуск)" Foreground="#339AF0" FontSize="11" />
                            <TextBlock Text="● Серый — Информационные сообщения (INFO)" Foreground="#ADB5BD" FontSize="11" />
                        </StackPanel>
                    </ToolTip>
                </ToolTipService.ToolTip>
            </FontIcon>
        </Grid>

        <!-- 1. Tool deck Card -->
        <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}" Padding="16" Margin="0,0,0,16">
            <Grid ColumnSpacing="12" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                <!-- Search Box -->
                <TextBox Grid.Column="0" x:Name="SearchTextBox" PlaceholderText="Поиск по строкам лога..." TextChanged="FilterInputs_Changed" Height="36" />

                <!-- Filter Dropdown -->
                <ComboBox Grid.Column="1" x:Name="LevelFilterComboBox" Width="200" SelectionChanged="FilterInputs_Changed" Height="36">
                    <ComboBoxItem Content="Все уровни логов" Tag="all" IsSelected="True" />
                    <ComboBoxItem Content="Только ошибки" Tag="errors" />
                    <ComboBoxItem Content="Только запуск/службы" Tag="service" />
                    <ComboBoxItem Content="Прямой вывод winws" Tag="winws" />
                </ComboBox>

                <!-- Action Button: Copy -->
                <Button Grid.Column="2" x:Name="CopyLogsButton" Click="CopyLogsButton_Click" Width="36" Height="36" Padding="0" ToolTipService.ToolTip="Копировать отфильтрованный лог">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8C8;" FontSize="16" />
                </Button>

                <!-- Action Button: Open in Notepad -->
                <Button Grid.Column="3" x:Name="OpenInNotepadButton" Click="OpenInNotepadButton_Click" Width="36" Height="36" Padding="0" ToolTipService.ToolTip="Открыть весь лог во внешнем Блокноте">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8E5;" FontSize="16" />
                </Button>

                <!-- Action Button: Export -->
                <Button Grid.Column="4" x:Name="ExportButton" Click="ExportButton_Click" Width="36" Height="36" Padding="0" ToolTipService.ToolTip="Экспортировать логи в текстовый файл">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74E;" FontSize="16" />
                </Button>

                <!-- Action Button: Clear -->
                <Button Grid.Column="5" x:Name="ClearLogsButton" Click="ClearLogsButton_Click" Style="{StaticResource PremiumAccentButtonStyle}" Width="36" Height="36" Padding="0" ToolTipService.ToolTip="Очистить буфер логов">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74D;" FontSize="16" />
                </Button>
            </Grid>
        </Border>

        <!-- 2. Dark Terminal Viewport -->
        <Border Grid.Row="2" Style="{StaticResource GlassCardStyle}" Padding="6" Background="#0C0C0C" BorderBrush="#1F1F1F">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <RichTextBlock x:Name="LogRichTextBlock" IsTextSelectionEnabled="True" FontFamily="Consolas" FontSize="12" Foreground="#F3EFE6" TextWrapping="NoWrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
